<UserControl x:Class="TrueforceForAll.Plugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignHeight="900" d:DesignWidth="700">
    <UserControl.Resources>
        <Style x:Key="SectionHeaderBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,0,0,8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="HelpText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style x:Key="OverrideBadge" TargetType="TextBlock">
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FFD54F"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Text" Value="★ car override"/>
        </Style>
        <!-- Custom-templated effect-header buttons. SimHub's stock theme greys
             every Button.Background; a full ControlTemplate replaces the visual
             tree so our accent colors survive. Test = always visible blue.
             Save = only visible when that section is dirty (toggled from
             code-behind), amber to draw attention to the unsaved state. -->
        <Style x:Key="EffectTestButton" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="14,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#3A6BBE" CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2F5DA6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#234A88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#555"/>
                                <Setter Property="Foreground" Value="#AAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EffectRevertButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ToolTip" Value="Discard unsaved changes — revert to the active preset's saved values."/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#6E6E6E" CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5C5C5C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Main Save preset button — saves everything (whole snapshot).
             Visually adapts to dirty state via Tag: when code-behind sets
             Tag="dirty", amber accent + larger; when Tag is empty, grey
             subtle. Content is also flipped between "Save preset" and
             "★ Save all changes" from code-behind. -->
        <Style x:Key="SaveAllPresetButton" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#555" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="dirty">
                                <Setter TargetName="Bd" Property="Background" Value="#FFB300"/>
                                <Setter Property="Foreground" Value="#1A1A1A"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#666"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="dirty"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#FFA000"/>
                            </MultiTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsPressed" Value="True"/>
                                    <Condition Property="Tag" Value="dirty"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#E69100"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EffectSaveButton" TargetType="Button">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="ToolTip" Value="Unsaved changes — click to save (per-car or to preset)."/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#FFB300" CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFA000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E69100"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Trueforce For All" FontSize="22" FontWeight="Bold"/>
                <TextBlock x:Name="HeaderVersionText" Text="" FontSize="13" Opacity="0.5"
                           VerticalAlignment="Bottom" Margin="8,0,0,3"/>
            </StackPanel>
            <TextBlock Text="Brings Trueforce-style haptics to any SimHub-enabled game. Unofficial — a reverse-engineered implementation of Logitech's Trueforce protocol, not affiliated with Logitech. Supports G PRO / RS50 wheels."
                       FontSize="13" Opacity="0.7" Margin="0,0,0,12" TextWrapping="Wrap"/>

            <!-- Update-available banner. Hidden until UpdateChecker confirms
                 a newer GitHub release. Click opens a modal with the changelog
                 and an "Update now" button that downloads + runs the new
                 installer. -->
            <Border x:Name="UpdateBanner" Visibility="Collapsed"
                    Background="#FFB300" CornerRadius="4" Padding="10,8,10,8" Margin="0,0,0,10"
                    Cursor="Hand" MouseLeftButtonUp="UpdateBanner_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="UpdateBannerText" Foreground="#222"
                               FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"
                               Text="Update available"/>
                    <TextBlock Grid.Column="1" Foreground="#222" Opacity="0.7"
                               FontSize="12" VerticalAlignment="Center" Text="View →"/>
                </Grid>
            </Border>

            <!-- Header strip: master toggle + at-a-glance context.
                 Just Game / Car / Preset and a single status pill — verbose
                 wheel/stream/telemetry strings live in Diagnostics. -->
            <Border Background="#22FFFFFF" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <CheckBox x:Name="PluginEnabledCheck" FontSize="14" FontWeight="SemiBold"
                              Content="Plugin enabled"
                              Checked="PluginEnabled_Changed" Unchecked="PluginEnabled_Changed"/>
                    <TextBlock x:Name="PluginEnabledHint" FontSize="11" Opacity="0.6"
                               TextWrapping="Wrap" Margin="22,4,0,10"
                               Text="Auto-remembered per game. Disable for games with native Trueforce (e.g. iRacing) so this plugin yields the wheel."/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Game"   FontSize="12" Opacity="0.6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="HeaderGameText"   Text="(none)" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Car"    FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="HeaderCarText"    Text="(none)" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Preset" FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="HeaderPresetText" Text="(none)" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    </Grid>

                    <!-- Status pill: single colored badge that says "is it
                         working?" plus an optional gold "Enhanced N Hz" hype
                         badge when high-fidelity per-game telemetry is in use. -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Border x:Name="StatusPill" CornerRadius="10" Padding="10,3" Background="#3D8B40">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusPillDot" Width="8" Height="8" Fill="#A5D6A7" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="StatusPillText" Text="Idle" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="EnhancedBadge" CornerRadius="10" Padding="10,3" Background="#FFB300"
                                Margin="6,0,0,0" Visibility="Collapsed"
                                ToolTip="Per-game enhanced telemetry source — higher rate / more physics signals than the standard SimHub data pipe.">
                            <TextBlock x:Name="EnhancedBadgeText" Text="✨ Enhanced" Foreground="#1A1A1A" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Logitech G HUB warning banner. G HUB claims the wheel's
                         HID interface; while it's running we can't talk to the
                         wheel. Surfaced as a dedicated red banner (separate from
                         the WheelQuietDiagnostic below) so the user sees it even
                         when other issues coexist (e.g., master gain also at 0).
                         Hidden when G HUB isn't detected. -->
                    <Border x:Name="GHubWarningBox" Visibility="Collapsed"
                            Background="#D32F2F" CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Foreground="White" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"
                                       Text="Logitech G HUB is running. Close it, then reload the Trueforce plugin from SimHub's Plugins page (G HUB claims the wheel and blocks Trueforce)."/>
                        </StackPanel>
                    </Border>

                    <!-- Why-is-my-wheel-quiet diagnostic. Shown only when the
                         plugin detects a likely reason output is silent —
                         master switch off, wheel disconnected, no telemetry,
                         all effects disabled, ducker swallowing everything,
                         etc. Hidden when healthy. Yellow background so it's
                         visually distinct from regular status text. -->
                    <Border x:Name="WheelQuietDiagnosticBox" Visibility="Collapsed"
                            Background="#FFC107" CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="14" Foreground="#222" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="WheelQuietDiagnosticText" Foreground="#222"
                                       FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"
                                       Text=""/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Master -->
            <Border Style="{StaticResource SectionHeaderBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Master" Style="{StaticResource SectionHeaderText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="MasterRevertBtn" Content="↶" Tag="Master" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                    <Button Grid.Column="2" x:Name="MasterSaveBtn"   Content="Save…" Tag="Master" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                </Grid>
            </Border>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Master gain:" Style="{StaticResource LabelText}"/>
                <Slider     Grid.Column="1" x:Name="MasterGainSlider"
                            Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                            TickFrequency="0.25" ValueChanged="MasterGainSlider_ValueChanged" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="MasterGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
            </Grid>
            <CheckBox x:Name="FfbSkipPassthroughCheck" Content="Skip FFB pass-through (native Trueforce games)"
                      Margin="0,0,0,2" Checked="FfbSkipPassthrough_Changed" Unchecked="FfbSkipPassthrough_Changed"/>
            <TextBlock Style="{StaticResource HelpText}" Margin="22,0,0,12"
                       Text="Enable for games with native Trueforce support (e.g. AC Rally, iRacing). Plugin effects still play, but the wheel's force comes from the game's own FFB path instead of being mirrored from our capture — avoids fighting with the game's own writes to the wheel."/>

            <!-- FFB pass-through controls — greyed when SkipFfbPassthrough is on. -->
            <StackPanel x:Name="FfbPassthroughControls">
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FFB scale:" Style="{StaticResource LabelText}"/>
                    <Slider     Grid.Column="1" x:Name="FfbScaleSlider"
                                Minimum="0" Maximum="1.5" SmallChange="0.05" LargeChange="0.1"
                                TickFrequency="0.25" ValueChanged="FfbScaleSlider_ValueChanged" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" x:Name="FfbScaleText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FFB smooth (ms):" Style="{StaticResource LabelText}"
                               ToolTip="Low-pass on AC's incoming FFB target. AC sends FFB updates every ~7 ms; smoothing converts the staircase into a ramp. Higher = smoother feel but more lag. Lower = tighter response but possible faint mechanical tick. 0 = pure passthrough (tightest response)."/>
                    <Slider     Grid.Column="1" x:Name="FfbSmoothSlider"
                                Minimum="0" Maximum="10" SmallChange="0.5" LargeChange="1"
                                TickFrequency="1" ValueChanged="FfbSmoothSlider_ValueChanged" VerticalAlignment="Center"
                                ToolTip="Low-pass on AC's incoming FFB target. AC sends FFB updates every ~7 ms; smoothing converts the staircase into a ramp. Higher = smoother feel but more lag. Lower = tighter response but possible faint mechanical tick. 0 = pure passthrough (tightest response)."/>
                    <TextBlock Grid.Column="2" x:Name="FfbSmoothText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.0"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="1" x:Name="FfbInvertCheck" Content="Invert FFB sign (uncheck if forces feel reversed)"
                              VerticalAlignment="Center" Checked="FfbInvert_Changed" Unchecked="FfbInvert_Changed"/>
                </Grid>

            </StackPanel>

            <!-- Active car -->
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="Active car" Style="{StaticResource SectionHeaderText}"/></Border>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Active preset:" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <ComboBox  Grid.Column="1" x:Name="CarPresetCombo"
                           VerticalAlignment="Center"
                           SelectionChanged="CarPresetCombo_Changed"
                           ToolTip="Switch which preset is active for this car. Selecting a preset reloads its tuning into the live effects. (default) presets are built-in and can't be deleted; saving changes while on one forks a new user preset."/>
                <Button    Grid.Column="2" x:Name="SaveCarPresetButton" Content="Save…" Width="80" Height="26" Margin="6,0,0,0"
                           Click="SaveCarPreset_Click"
                           ToolTip="Save the current per-car tuning. On a built-in default this prompts for a new preset name and forks; on a user preset it updates in place."/>
                <Button    Grid.Column="3" x:Name="DeleteCarPresetButton" Content="Delete" Width="70" Height="26" Margin="6,0,0,0"
                           Click="DeleteCarPreset_Click"
                           ToolTip="Delete the active user preset. Built-in (default) presets can't be deleted."/>
            </Grid>
            <TextBlock x:Name="ActiveCarHint" Style="{StaticResource HelpText}" Margin="0,0,0,20" FontSize="12"
                       Text="Per-car tuning lives in named presets under PluginsData/Common/TrueforceCars. Each car can have multiple presets — built-in defaults shipped with the plugin plus any user-saved or imported ones. Sharing a preset is sharing the file."/>

            <!-- FFB spike taming: comfort filter for over-the-top curb /
                 collision FFB. Pulled out into its own top-level section
                 (was nested inside Master's FFB controls) since it's a
                 distinct safety / comfort feature, not just FFB tuning. -->
            <Border Style="{StaticResource SectionHeaderBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FFB spike reduction" Style="{StaticResource SectionHeaderText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="SpikeReductionRevertBtn" Content="↶" Tag="SpikeReduction" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                    <Button Grid.Column="2" x:Name="SpikeReductionSaveBtn"   Content="Save…" Tag="SpikeReduction" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                </Grid>
            </Border>
            <CheckBox x:Name="SpikeTamingEnabledCheck" Content="FFB spike reduction (recommended for Assetto Corsa)"
                      FontWeight="SemiBold" Margin="0,0,0,4"
                      Checked="SpikeTamingEnabled_Changed" Unchecked="SpikeTamingEnabled_Changed"/>
            <StackPanel x:Name="SpikeTamingBody" Margin="0,4,0,16"
                        IsEnabled="{Binding IsChecked, ElementName=SpikeTamingEnabledCheck}">
                <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8"
                           Text="Some games deliver curb and collision FFB spikes well beyond what's safe or comfortable on stronger wheelbases (Assetto Corsa is the worst offender we've seen). Hits can be sharp enough to wrench the wheel against your grip, ruin a racing line, or strain your wrists on a long session. This attenuates spikes only; sustained cornering load is untouched. Lower values = stronger reduction."/>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Spike attenuation:" Style="{StaticResource LabelText}"/>
                    <Slider     Grid.Column="1" x:Name="FfbPeakLimitSlider"
                                Minimum="0" Maximum="20000" SmallChange="500" LargeChange="2000"
                                TickFrequency="2000" ValueChanged="FfbPeakLimitSlider_ValueChanged" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" x:Name="FfbPeakLimitText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1562"/>
                </Grid>
                <Expander x:Name="SpikeTamingAdvancedExpander" IsExpanded="False" Margin="0,12,0,0">
                    <Expander.Header>
                        <TextBlock Text="Advanced" FontSize="11" Opacity="0.7"/>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Rate limit (LSB/ms):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="FfbSpikeLimitSlider"
                                        Minimum="0" Maximum="10000" SmallChange="100" LargeChange="500"
                                        TickFrequency="1000" ValueChanged="FfbSpikeLimitSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="FfbSpikeLimitText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="2061"/>
                        </Grid>
                        <TextBlock Style="{StaticResource HelpText}" Margin="140,4,0,0"
                                   Text="Caps how fast FFB can change in either direction. Pairs with Spike attenuation (which controls how much spikes are reduced); this controls how fast they're allowed to ramp. The default value rarely needs adjustment."/>
                    </StackPanel>
                </Expander>
            </StackPanel>

            <!-- Effects -->
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="Effects" Style="{StaticResource SectionHeaderText}"/></Border>

            <!-- Audio capture (game audio → wheel). Lives outside the
                 telemetry-greyed panel because it works even when the game
                 emits no useful telemetry (custom SimHub games etc). -->
            <Expander x:Name="AudioExpander" IsExpanded="False" Margin="0,0,0,4">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="AudioEnabledCheck" Content="Audio capture (game audio → wheel)"
                                  FontWeight="SemiBold" VerticalAlignment="Center"
                                  Checked="AudioEnabled_Changed" Unchecked="AudioEnabled_Changed"/>
                        <TextBlock x:Name="AudioOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                        <Button    x:Name="AudioRevertBtn"  Content="↶" Tag="Audio" Margin="14,0,0,0"
                                   Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                        <Button    x:Name="AudioSaveBtn"    Content="Save…" Tag="Audio"
                                   Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                        <Slider     Grid.Column="1" x:Name="AudioGainSlider"
                                    Minimum="0" Maximum="3.0" SmallChange="0.05" LargeChange="0.25"
                                    TickFrequency="0.5" ValueChanged="AudioGainSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="AudioGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Highpass (Hz):" Style="{StaticResource LabelText}"/>
                        <Slider     Grid.Column="1" x:Name="AudioHighpassSlider"
                                    Minimum="0" Maximum="200" SmallChange="5" LargeChange="20"
                                    TickFrequency="20" ValueChanged="AudioHighpassSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="AudioHighpassText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="30"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Lowpass (Hz):" Style="{StaticResource LabelText}"/>
                        <Slider     Grid.Column="1" x:Name="AudioFilterSlider"
                                    Minimum="100" Maximum="1500" SmallChange="10" LargeChange="50"
                                    TickFrequency="100" ValueChanged="AudioFilterSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="AudioFilterText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="350"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Level:" Style="{StaticResource LabelText}"/>
                        <ProgressBar Grid.Column="1" x:Name="AudioLevelMeter" Minimum="0" Maximum="1" Height="14" Foreground="#4CAF50"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Status:" Style="{StaticResource LabelText}"/>
                        <TextBlock Grid.Column="1" x:Name="CaptureStatusText" Text="Idle" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </Grid>

                    <!-- Power-user: per-game capture exe override. Hidden by
                         default; surfaces when auto-detect misses a game. -->
                    <Expander x:Name="CaptureNotWorkingExpander" IsExpanded="False" Margin="0,8,0,0">
                        <Expander.Header>
                            <TextBlock Text="Audio capture not picking up your game?" FontSize="12"/>
                        </Expander.Header>
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,4"
                                       Text="Type the game's exe name here (with or without &quot;.exe&quot;). Saved per-game and applied within 1 second."/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Capture exe:" Style="{StaticResource LabelText}"/>
                                <TextBox   Grid.Column="1" x:Name="CaptureExeOverrideBox"
                                           VerticalAlignment="Center" LostFocus="CaptureExeOverride_LostFocus"
                                           KeyDown="CaptureExeOverride_KeyDown"/>
                            </Grid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Expander>

            <!-- Telemetry-driven effects: greyed when a game is running but
                 emits no useful telemetry (e.g. SimHub custom games where
                 only audio capture produces output). When no game is loaded,
                 the panel stays enabled so the user can still tune presets
                 for future sessions. -->
            <StackPanel x:Name="TelemetryEffectsPanel">

                <!-- Engine pulse -->
                <Expander x:Name="EngineExpander" IsExpanded="False" Margin="0,0,0,4">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="EngineEnabledCheck" Content="Engine pulse (RPM-driven)"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="EngineEnabled_Changed" Unchecked="EngineEnabled_Changed"/>
                            <TextBlock x:Name="EngineOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="EngineTest_Click"/>
                            <Button x:Name="EngineRevertBtn" Content="↶" Tag="Engine" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="EngineSaveBtn"   Content="Save…" Tag="Engine" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="EngineGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="EngineGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="EngineGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <!-- Cylinders slider: 0 = auto (use resolver / telemetry value);
                             1-12 = manual override. The text readout to the right shows
                             "auto" at position 0, the number elsewhere. Drag all the way
                             left to engage auto-detection; drag right to dial in a specific
                             count. The status text below explains what's currently in effect. -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cylinders:" Style="{StaticResource LabelText}"
                                       ToolTip="Drag to 'auto' (leftmost) to use the cylinder count detected for the active car, or pick a specific count to override detection."/>
                            <Slider     Grid.Column="1" x:Name="EngineCylindersSlider" Minimum="0" Maximum="12" SmallChange="1" LargeChange="2"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="EngineCylindersSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="EngineCylindersText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="auto"/>
                        </Grid>
                        <!-- Auto-detect indicator: when telemetry supplies a per-car
                             cylinder count (Forza's NumCylinders today), shows what
                             the firing-frequency calc is actually using. Empty when
                             no auto value is available — slider value is in effect. -->
                        <TextBlock x:Name="EngineCylindersAutoText" Style="{StaticResource HelpText}" Margin="140,0,0,4" Text=""/>
                        <!-- Report-wrong button: opens a pre-filled GitHub issue for
                             the active car so users can correct bake / heuristic mistakes
                             without needing to know the carId or source attribution. -->
                        <Grid Margin="140,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Button x:Name="ReportWrongCylindersButton"
                                    HorizontalAlignment="Left" Padding="8,3" Margin="0,2,0,0"
                                    Click="ReportWrongCylindersButton_Click"
                                    Content="Report wrong cylinder count for this car…"
                                    ToolTip="Opens a pre-filled report on GitHub. Use this if the auto-detected count sounds wrong for the active car (most often for engine-swapped drift mods)."/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pitch:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="EnginePitchSlider" Minimum="0.25" Maximum="4.0" SmallChange="0.05" LargeChange="0.25"
                                        TickFrequency="0.25" ValueChanged="EnginePitchSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="EnginePitchText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="EngineWaveformCombo" SelectionChanged="EngineWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Lowpass (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="0 = disabled. Lowers buzzy harmonics on Square/Saw without changing pitch."/>
                            <Slider     Grid.Column="1" x:Name="EngineLowpassSlider" Minimum="0" Maximum="2000" SmallChange="10" LargeChange="50"
                                        TickFrequency="200" ValueChanged="EngineLowpassSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="EngineLowpassText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0"/>
                        </Grid>
                        <!-- Electric car behavior: applies only when the resolver
                             flags the active car as a pure EV. Combustion cars
                             ignore this. Per-car preset overrides the global. -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Electric cars:" Style="{StaticResource LabelText}"
                                       ToolTip="What EnginePulse does for cars detected as pure electric. Most users prefer the muted hum since real EVs aren't silent — many pump synthetic engine sound. Pick Silent if you want true silence on EVs."/>
                            <ComboBox  Grid.Column="1" x:Name="EngineElectricModeCombo" SelectionChanged="EngineElectricMode_Changed">
                                <ComboBoxItem Content="Muted hum (50%)"/>
                                <ComboBoxItem Content="Silent (off)"/>
                            </ComboBox>
                        </Grid>
                        <!-- Firing-order pattern. When enabled, EnginePulse renders
                             the engine's true firing pattern (V8 cross-plane lope,
                             Ducati L-twin gap, V6 odd-fire lump, etc.) instead of
                             a uniform pulse train at firing frequency. Default off
                             so an in-place upgrade preserves users' current feel. -->
                        <Separator Margin="0,4,0,8"/>
                        <CheckBox x:Name="EngineFiringOrderCheck" Content="Firing-order accurate pulses"
                                  Margin="140,0,0,4"
                                  Checked="EngineFiringOrder_Changed" Unchecked="EngineFiringOrder_Changed"
                                  ToolTip="When enabled, the pulse train follows the engine's actual firing pattern instead of a uniform tone. Most pronounced on V8 cross-plane (American lope), V-twin (Ducati / Harley), and V6 odd-fire engines. Toggle to A/B against the original feel."/>
                        <TextBlock Style="{StaticResource HelpText}" Margin="140,0,0,8"
                                   TextWrapping="Wrap"
                                   Text="Off = uniform pulse train at firing frequency (legacy). On = pattern-aware synthesis driven by Engine layout below."/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Engine layout:" Style="{StaticResource LabelText}"
                                       ToolTip="Auto picks from cylinder count using the most common modern config (V6 60° / V8 cross-plane / V12 60°). Pick an explicit value to get characterful patterns: V8 flat-plane, V-twin variants, V6 odd-fire, rotary."/>
                            <ComboBox  Grid.Column="1" x:Name="EngineConfigCombo" SelectionChanged="EngineConfig_Changed">
                                <ComboBoxItem Content="Auto (from cylinder count)"/>
                                <ComboBoxItem Content="Inline / even-fire"/>
                                <ComboBoxItem Content="Boxer (Subaru / Porsche)"/>
                                <ComboBoxItem Content="V60° even-fire (V6 / V12)"/>
                                <ComboBoxItem Content="V90° even-fire"/>
                                <ComboBoxItem Content="V8 cross-plane (American lope)"/>
                                <ComboBoxItem Content="V8 flat-plane (Ferrari / Lotus)"/>
                                <ComboBoxItem Content="V6 odd-fire 90° (older muscle)"/>
                                <ComboBoxItem Content="V-twin 90° (Ducati)"/>
                                <ComboBoxItem Content="V-twin 45° (Harley)"/>
                                <ComboBoxItem Content="Rotary"/>
                                <ComboBoxItem Content="Custom (advanced)"/>
                            </ComboBox>
                        </Grid>
                        <!-- Active pattern readout: shows what the resolver picked
                             (or the user's custom). Read-only — the textbox is
                             editable only when "Custom" is the selected layout. -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pattern:" Style="{StaticResource LabelText}"
                                       ToolTip="Comma-separated phase positions in [0, 1) representing where each cylinder fires within one 720° engine cycle. Optional ':amplitude' suffix per pulse. Read-only unless Engine layout is set to Custom."/>
                            <TextBox   Grid.Column="1" x:Name="EngineFiringPatternText"
                                       FontFamily="Consolas" IsReadOnly="True"
                                       LostFocus="EngineFiringPattern_LostFocus"/>
                        </Grid>
                        <TextBlock Style="{StaticResource HelpText}" Margin="140,0,0,4"
                                   TextWrapping="Wrap"
                                   Text="Format: 0, 0.125, 0.25, ...  Optional weights: 0:1.0, 0.125:0.85, ..."/>
                        <!-- Report-engine-data button: opens a pre-filled GitHub
                             issue with the currently-cached engine state +
                             whatever the user has manually overridden, so
                             corrections / contributions are one click. The
                             button label changes by context: existing cached
                             car -> "Report wrong engine data"; uncached car
                             with manual values -> "Submit engine data for
                             this car". Hidden when no car is loaded. -->
                        <Grid Margin="140,4,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Button x:Name="ReportEngineDataButton"
                                    HorizontalAlignment="Left" Padding="8,3"
                                    Click="ReportEngineDataButton_Click"
                                    Content="Submit engine data for this car…"
                                    ToolTip="Opens a Google Form pre-filled with what's auto-detected and what you've selected in the dropdowns / slider. Just hit Submit on the form, no typing needed and no account required."/>
                        </Grid>
                        <!-- Coverage readout: how often the resolver is producing
                             specific layout info this session, broken down by
                             baked vs heuristic. Lets users see whether the
                             firing-order feature is actually firing for cars
                             they drive. Refreshed by the same UI tick that
                             updates other live counters. -->
                        <TextBlock x:Name="EngineCoverageText" Style="{StaticResource HelpText}"
                                   Margin="140,0,0,0" TextWrapping="Wrap"
                                   FontStyle="Italic"
                                   Text="No cars resolved yet."/>
                    </StackPanel>
                </Expander>

                <!-- Road bumps -->
                <Expander x:Name="BumpsExpander" IsExpanded="False" Margin="0,0,0,4">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="SlipEnabledCheck" Content="Road bumps / curbs (vertical jolts)"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="SlipEnabled_Changed" Unchecked="SlipEnabled_Changed"/>
                            <TextBlock x:Name="BumpsOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="BumpsTest_Click"/>
                            <Button x:Name="BumpsRevertBtn" Content="↶" Tag="Bumps" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="BumpsSaveBtn"   Content="Save…" Tag="Bumps" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="SlipGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="SlipGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="SlipGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="BumpsWaveformCombo" SelectionChanged="BumpsWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid x:Name="BumpsFreqRow" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Frequency (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="BumpsFreqSlider" Minimum="20" Maximum="300" SmallChange="1" LargeChange="10"
                                        TickFrequency="20" ValueChanged="BumpsFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="BumpsFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="60"/>
                        </Grid>

                        <!-- Surface texture (Forza-supplied SurfaceRumble + WheelOnRumbleStrip).
                             Has its own oscillator so the user can pick a higher freq /
                             brighter waveform than the heave path. Knobs stay visible
                             on non-Forza games but won't produce sound (source supplies
                             no SurfaceRumble) — clearly labeled (Forza) so users don't
                             waste time tuning controls that won't fire on AC etc. -->
                        <Border BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF" Margin="0,4,0,8" Padding="0,8,0,0">
                            <StackPanel>
                                <CheckBox x:Name="BumpsSurfaceEnabledCheck" Content="Surface texture (Forza)" FontWeight="SemiBold" Margin="0,0,0,4"
                                          Checked="BumpsSurfaceEnabled_Changed" Unchecked="BumpsSurfaceEnabled_Changed"
                                          ToolTip="Forza-only: drives a second oscillator from the per-tire SurfaceRumble channel. Continuous road feel that's stronger on dirt/grass and lighter on asphalt. Adds a leading-edge pulse on rumble-strip contact."/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface gain:" Style="{StaticResource LabelText}"/>
                                    <Slider     Grid.Column="1" x:Name="BumpsSurfaceGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                                TickFrequency="0.25" ValueChanged="BumpsSurfaceGainSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="BumpsSurfaceGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface freq (Hz):" Style="{StaticResource LabelText}"/>
                                    <Slider     Grid.Column="1" x:Name="BumpsSurfaceFreqSlider" Minimum="20" Maximum="600" SmallChange="5" LargeChange="25"
                                                TickFrequency="50" ValueChanged="BumpsSurfaceFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="BumpsSurfaceFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="120"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface waveform:" Style="{StaticResource LabelText}"/>
                                    <ComboBox  Grid.Column="1" x:Name="BumpsSurfaceWaveformCombo" SelectionChanged="BumpsSurfaceWaveform_Changed">
                                        <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Rumble scale:" Style="{StaticResource LabelText}"
                                               ToolTip="Multiplier on Forza's SurfaceRumble before driving the oscillator. 1.0 = use as-is. Bump up for more aggressive surface feel."/>
                                    <Slider     Grid.Column="1" x:Name="BumpsSurfaceRumbleScaleSlider" Minimum="0.1" Maximum="3.0" SmallChange="0.1" LargeChange="0.25"
                                                TickFrequency="0.25" ValueChanged="BumpsSurfaceRumbleScaleSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="BumpsSurfaceRumbleScaleText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                                </Grid>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Kerb pulse:" Style="{StaticResource LabelText}"
                                               ToolTip="Extra amplitude added on the rising edge of any wheel touching a rumble strip. 0 = disabled."/>
                                    <Slider     Grid.Column="1" x:Name="BumpsRumbleStripPulseSlider" Minimum="0" Maximum="1.5" SmallChange="0.05" LargeChange="0.1"
                                                TickFrequency="0.25" ValueChanged="BumpsRumbleStripPulseSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="BumpsRumbleStripPulseText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.50"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Expander>

                <!-- Traction loss -->
                <Expander x:Name="TractionExpander" IsExpanded="False" Margin="0,0,0,4">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="TractionEnabledCheck" Content="Traction loss (rear breaking loose / wheelspin)"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="TractionEnabled_Changed" Unchecked="TractionEnabled_Changed"/>
                            <TextBlock x:Name="TractionOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="TractionTest_Click"/>
                            <Button x:Name="TractionRevertBtn" Content="↶" Tag="Traction" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="TractionSaveBtn"   Content="Save…" Tag="Traction" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="TractionGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="TractionGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TractionGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sensitivity:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="TractionSensitivitySlider" Minimum="0.1" Maximum="3.0" SmallChange="0.1" LargeChange="0.25"
                                        TickFrequency="0.25" ValueChanged="TractionSensitivitySlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TractionSensitivityText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="TractionWaveformCombo" SelectionChanged="TractionWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid x:Name="TractionFreqRow" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Frequency (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="TractionFreqSlider" Minimum="20" Maximum="300" SmallChange="1" LargeChange="10"
                                        TickFrequency="20" ValueChanged="TractionFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TractionFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="100"/>
                        </Grid>
                        <!-- Noise filter rows: only relevant for Noise waveform.
                             Collapsed otherwise so the panel doesn't show
                             controls that have no audible effect. -->
                        <Grid x:Name="TractionNoiseLpRow" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Noise lowpass (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="Cut high frequencies from noise — lower = smoother rumble, higher = grittier."/>
                            <Slider     Grid.Column="1" x:Name="TractionNoiseLpSlider" Minimum="50" Maximum="1000" SmallChange="10" LargeChange="50"
                                        TickFrequency="100" ValueChanged="TractionNoiseLpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TractionNoiseLpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="250"/>
                        </Grid>
                        <Grid x:Name="TractionNoiseHpRow" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Noise highpass (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="Cut sub-audible drift / DC thump from noise. 0 disables."/>
                            <Slider     Grid.Column="1" x:Name="TractionNoiseHpSlider" Minimum="0" Maximum="200" SmallChange="5" LargeChange="20"
                                        TickFrequency="20" ValueChanged="TractionNoiseHpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TractionNoiseHpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="30"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Gear shift -->
                <Expander x:Name="ShiftExpander" IsExpanded="False" Margin="0,0,0,4">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="ShiftEnabledCheck" Content="Gear shift thud"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="ShiftEnabled_Changed" Unchecked="ShiftEnabled_Changed"/>
                            <TextBlock x:Name="ShiftOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="ShiftTest_Click"/>
                            <Button x:Name="ShiftRevertBtn" Content="↶" Tag="Shift" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="ShiftSaveBtn"   Content="Save…" Tag="Shift" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="ShiftGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="ShiftGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="ShiftGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="ShiftWaveformCombo" SelectionChanged="ShiftWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Frequency (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="ShiftFreqSlider" Minimum="20" Maximum="100" SmallChange="1" LargeChange="5"
                                        TickFrequency="10" ValueChanged="ShiftFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="ShiftFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="40"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- ABS -->
                <Expander x:Name="AbsExpander" IsExpanded="False" Margin="0,0,0,16">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="AbsEnabledCheck" Content="ABS pulse"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="AbsEnabled_Changed" Unchecked="AbsEnabled_Changed"/>
                            <TextBlock x:Name="AbsOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="AbsTest_Click"/>
                            <Button x:Name="AbsRevertBtn" Content="↶" Tag="Abs" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="AbsSaveBtn"   Content="Save…" Tag="Abs" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="AbsGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="AbsGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="AbsGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="AbsWaveformCombo" SelectionChanged="AbsWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mode:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="AbsModeCombo" SelectionChanged="AbsMode_Changed">
                                <ComboBoxItem Content="Pulse (rhythmic)"/>
                                <ComboBoxItem Content="PerTick (one click per ABS pump)"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Carrier (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="AbsFreqSlider" Minimum="30" Maximum="150" SmallChange="1" LargeChange="5"
                                        TickFrequency="10" ValueChanged="AbsFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="AbsFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="80"/>
                        </Grid>
                        <!-- Pulse rate / duty are only meaningful in Pulse mode.
                             Greyed when AbsMode = PerTick. -->
                        <StackPanel x:Name="AbsPulseControls">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pulse rate (Hz):" Style="{StaticResource LabelText}"/>
                                <Slider     Grid.Column="1" x:Name="AbsPulseFreqSlider" Minimum="3" Maximum="30" SmallChange="0.5" LargeChange="2"
                                            TickFrequency="2" ValueChanged="AbsPulseFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="AbsPulseFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pulse duty:" Style="{StaticResource LabelText}"/>
                                <Slider     Grid.Column="1" x:Name="AbsDutyCycleSlider" Minimum="0.1" Maximum="0.9" SmallChange="0.05" LargeChange="0.1"
                                            TickFrequency="0.1" ValueChanged="AbsDutyCycleSlider_ValueChanged" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="AbsDutyCycleText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.40"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <!-- Pit limiter — modal flag effect. Pulse train while the
                     pit limiter is engaged. Most modern racing sims surface
                     PitLimiterOn directly via SimHub. -->
                <Expander x:Name="PitLimiterExpander" IsExpanded="False" Margin="0,0,0,16">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="PitLimiterEnabledCheck" Content="Pit limiter"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="PitLimiterEnabled_Changed" Unchecked="PitLimiterEnabled_Changed"/>
                            <TextBlock x:Name="PitLimiterOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="PitLimiterTest_Click"/>
                            <Button x:Name="PitLimiterRevertBtn" Content="↶" Tag="PitLimiter" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="PitLimiterSaveBtn"   Content="Save…" Tag="PitLimiter" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="Continuous pulse train while the pit limiter is engaged — feels like the engine being cut at low RPM. Source: SimHub StatusDataBase.PitLimiterOn (works for most racing sims that have a pit lane)."/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="PitLimiterGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="PitLimiterGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PitLimiterGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="PitLimiterWaveformCombo" SelectionChanged="PitLimiterWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Carrier (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="Tone within each pulse. Lower = deeper thud; higher = brighter."/>
                            <Slider     Grid.Column="1" x:Name="PitLimiterFreqSlider" Minimum="20" Maximum="150" SmallChange="1" LargeChange="5"
                                        TickFrequency="10" ValueChanged="PitLimiterFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PitLimiterFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="50"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pulse rate (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="How fast the pulse opens / closes. 5–10 Hz feels like a real pit limiter cadence."/>
                            <Slider     Grid.Column="1" x:Name="PitLimiterPulseFreqSlider" Minimum="3" Maximum="15" SmallChange="0.5" LargeChange="2"
                                        TickFrequency="1" ValueChanged="PitLimiterPulseFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PitLimiterPulseFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="6.0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pulse duty:" Style="{StaticResource LabelText}"
                                       ToolTip="Fraction of each pulse during which the carrier is audible. Higher = more sustained; lower = more punctuated."/>
                            <Slider     Grid.Column="1" x:Name="PitLimiterDutyCycleSlider" Minimum="0.1" Maximum="0.9" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.1" ValueChanged="PitLimiterDutyCycleSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PitLimiterDutyCycleText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.60"/>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Active amp:" Style="{StaticResource LabelText}"
                                       ToolTip="Peak amplitude while the limiter is engaged."/>
                            <Slider     Grid.Column="1" x:Name="PitLimiterActiveAmpSlider" Minimum="0" Maximum="0.6" SmallChange="0.02" LargeChange="0.05"
                                        TickFrequency="0.1" ValueChanged="PitLimiterActiveAmpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PitLimiterActiveAmpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.30"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- DRS — F1-style flag effect. Activation chirp on rising edge
                     plus low-amp sustained tone while wing is open. Source:
                     SimHub StatusDataBase.DRSEnabled (F1 / F1-like sims). -->
                <Expander x:Name="DrsExpander" IsExpanded="False" Margin="0,0,0,16">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="DrsEnabledCheck" Content="DRS"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="DrsEnabled_Changed" Unchecked="DrsEnabled_Changed"/>
                            <TextBlock x:Name="DrsOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="DrsTest_Click"/>
                            <Button x:Name="DrsRevertBtn" Content="↶" Tag="Drs" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="DrsSaveBtn"   Content="Save…" Tag="Drs" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="Brief activation chirp on the rising edge of DRS, plus a low-amplitude sustained tone while the wing stays open. Silent on games that don't expose DRS. Source: SimHub StatusDataBase.DRSEnabled."/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="DrsGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="DrsWaveformCombo" SelectionChanged="DrsWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,4,0,4" Text="Activation chirp (rising edge of DRS)" FontWeight="SemiBold"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Carrier (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsActivationFreqSlider" Minimum="40" Maximum="200" SmallChange="1" LargeChange="5"
                                        TickFrequency="20" ValueChanged="DrsActivationFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsActivationFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="120"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Duration (ms):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsActivationMsSlider" Minimum="20" Maximum="200" SmallChange="5" LargeChange="20"
                                        TickFrequency="20" ValueChanged="DrsActivationMsSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsActivationMsText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="60"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Amp:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsActivationAmpSlider" Minimum="0" Maximum="0.6" SmallChange="0.02" LargeChange="0.05"
                                        TickFrequency="0.1" ValueChanged="DrsActivationAmpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsActivationAmpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.30"/>
                        </Grid>
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,4,0,4" Text="Sustained tone (while DRS held open). Set amp to 0 for chirp-only mode." FontWeight="SemiBold"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Carrier (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsSustainedFreqSlider" Minimum="20" Maximum="150" SmallChange="1" LargeChange="5"
                                        TickFrequency="10" ValueChanged="DrsSustainedFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsSustainedFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="70"/>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Amp:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsSustainedAmpSlider" Minimum="0" Maximum="0.4" SmallChange="0.02" LargeChange="0.05"
                                        TickFrequency="0.05" ValueChanged="DrsSustainedAmpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsSustainedAmpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.12"/>
                        </Grid>
                    </StackPanel>
                </Expander>

            </StackPanel> <!-- /TelemetryEffectsPanel -->

            <!-- Sidechain ducking. Collapsed Expander, sits below the
                 telemetry effects with Performance and Presets so it groups
                 with other "global mixing / system" knobs rather than
                 visually splitting Audio from the telemetry voices. -->
            <Expander x:Name="DuckingExpander" IsExpanded="False" Margin="0,0,0,4">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Sidechain ducking" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="DuckingRevertBtn" Content="↶" Tag="Ducking" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                        <Button x:Name="DuckingSaveBtn"   Content="Save…" Tag="Ducking" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                        Text="When transient effects (gear shift, ABS, road bumps, traction loss) fire, continuous effects (engine pulse, audio capture) duck to make room."/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Depth:" Style="{StaticResource LabelText}"/>
                        <Slider     Grid.Column="1" x:Name="DuckDepthSlider"
                                    Minimum="0" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                                    TickFrequency="0.1" ValueChanged="DuckDepthSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="DuckDepthText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.50"/>
                    </Grid>
                    <Expander x:Name="AdvancedDuckingExpander" IsExpanded="False" Margin="0,4,0,0">
                        <Expander.Header>
                            <TextBlock Text="Advanced (envelope)" FontSize="12"/>
                        </Expander.Header>
                        <StackPanel Margin="0,8,0,0">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Attack (ms):" Style="{StaticResource LabelText}"/>
                                <Slider     Grid.Column="1" x:Name="DuckAttackSlider"
                                            Minimum="1" Maximum="100" SmallChange="1" LargeChange="5"
                                            TickFrequency="10" ValueChanged="DuckAttackSlider_ValueChanged" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="DuckAttackText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="5"/>
                            </Grid>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Release (ms):" Style="{StaticResource LabelText}"/>
                                <Slider     Grid.Column="1" x:Name="DuckReleaseSlider"
                                            Minimum="10" Maximum="500" SmallChange="5" LargeChange="25"
                                            TickFrequency="50" ValueChanged="DuckReleaseSlider_ValueChanged" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="DuckReleaseText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="80"/>
                            </Grid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Expander>

            <!-- Performance / latency tuning. Per-machine, NOT preset-saved
                 (a friend's CPU/scheduler is different from yours). Collapsed
                 Expander since most users never need to touch it. -->
            <Expander x:Name="PerformanceExpander" IsExpanded="False" Margin="0,0,0,16">
                <Expander.Header>
                    <TextBlock Text="Performance" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                        Text="Smaller ring buffers = less latency between game and wheel, but require Windows to wake our threads on time. Auto starts at the smallest sizes and ratchets up if dropouts occur (one-way; survived size persists across sessions). Manual locks specific sizes — useful for streamers who want guaranteed-stable behavior, or to force-test the lowest values."/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mode:" VerticalAlignment="Center" Opacity="0.7"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton x:Name="PerfAutoRadio"   Content="Auto" GroupName="PerfMode"
                                         Margin="0,0,16,0" VerticalAlignment="Center"
                                         ToolTip="Start at smallest ring sizes; ratchet up on persistent dropouts. Survived size is remembered across sessions."
                                         Checked="PerfMode_Changed"/>
                            <RadioButton x:Name="PerfManualRadio" Content="Manual" GroupName="PerfMode"
                                         Margin="0,0,16,0" VerticalAlignment="Center"
                                         ToolTip="Lock the slider values. No automatic changes. Use for streaming or force-testing."
                                         Checked="PerfMode_Changed"/>
                            <Button x:Name="PerfResetButton" Content="Reset to lowest" Padding="10,2" VerticalAlignment="Center"
                                    ToolTip="Drop both rings back to the smallest configured value. In Auto mode the ratchet will re-discover whether your machine can hold them."
                                    Click="PerfReset_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Trueforce ring:" VerticalAlignment="Center" Opacity="0.7"
                                   ToolTip="Sample buffer between the audio mixer and the USB stream. Smaller = lower wheel latency, but Windows must wake the stream thread on time."/>
                        <Slider     Grid.Column="1" x:Name="PerfTfRingSlider"
                                    Minimum="8" Maximum="64" SmallChange="8" LargeChange="8"
                                    TickFrequency="8" IsSnapToTickEnabled="True"
                                    ValueChanged="PerfTfRingSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="PerfTfRingText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="8 (2ms)"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Audio ring:" VerticalAlignment="Center" Opacity="0.7"
                                   ToolTip="Sample buffer between WASAPI loopback and the audio mixer. WASAPI typically delivers ~12 decimated samples per ~3ms callback; 16 fits that with headroom. Setting 8 only works if your audio driver supports a ~2ms WASAPI period — uncommon. If you set 8 and hear continuous clicks, the auto-ratchet (Auto mode) will bump you back up."/>
                        <Slider     Grid.Column="1" x:Name="PerfAudioRingSlider"
                                    Minimum="8" Maximum="128" SmallChange="8" LargeChange="8"
                                    TickFrequency="8" IsSnapToTickEnabled="True"
                                    ValueChanged="PerfAudioRingSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="PerfAudioRingText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="16 (4ms)"/>
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Live counters:" VerticalAlignment="Top" Opacity="0.7" Margin="0,2,0,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="PerfCountersText" FontSize="11" Opacity="0.8"
                                       Text="Trueforce ring: — underruns/min · Audio ring: — glitches/min"/>
                            <TextBlock Style="{StaticResource HelpText}" FontSize="11" Margin="0,2,0,0"
                                       Text="Counters tally events in a rolling 60-second window. If they're going up, your machine is glitching at the current ring size — Auto mode will bump it up."/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Forza Data Out (UDP). Forza titles emit telemetry over UDP
                 instead of shared memory; the user enables UDP RACE TELEMETRY
                 in the in-game Settings → HUD and Gameplay menu and points it
                 at the IP/port set here. Two real-world gotchas:
                  - MS Store / UWP build: Windows network isolation blocks
                    UDP loopback. User has to run CheckNetIsolation.exe to
                    add a loopback exemption (or send to a LAN IP).
                  - Steam build: FH5 sends to the gateway IP (a long-known
                    bug Playground hasn't fixed). User has to send to their
                    LAN IP, not 127.0.0.1.
                 The Always-listen toggle keeps the source open for FH6 day-1
                 (before SimHub's GameName recognizes it) or other Forza
                 variants the auto-detect doesn't cover. -->
            <StackPanel x:Name="ForzaSection" Visibility="Collapsed">
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="Forza telemetry (UDP)" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                Text="In Forza Horizon 5/6 (or Forza Motorsport), open Settings → HUD and Gameplay → UDP RACE TELEMETRY. Set DATA OUT IP ADDRESS to your machine's IP and DATA OUT IP PORT to the port below. Game-specific fields (per-tire surface rumble, kerbs, cylinder count) flow through and the 'Forza Horizon (default)' preset auto-loads."/>
            <CheckBox x:Name="ForzaEnabledCheck" Content="Enable Forza UDP listener" Click="ForzaEnabled_Changed" Margin="0,0,0,8"
                      ToolTip="When off, Forza titles fall back to SimHub's universal telemetry (engine + RPM only — no per-tire surface, no kerb pulses, no cylinder auto-detect)."/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Port:" Style="{StaticResource LabelText}"/>
                <TextBox   Grid.Column="1" x:Name="ForzaPortBox" LostFocus="ForzaPort_LostFocus" KeyDown="ForzaPort_KeyDown" VerticalAlignment="Center"
                           ToolTip="Match this in Forza's DATA OUT IP PORT. Default 5300; pick anything if it collides with another listener (SimHub's typical 4123, Sim Racing Studio's 4123, etc.)."/>
                <TextBlock Grid.Column="2" Style="{StaticResource HelpText}" Margin="8,0,0,0" VerticalAlignment="Center"
                           Text="Restart Trueforce (toggle plugin off+on) after changing."/>
            </Grid>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Bind address:" Style="{StaticResource LabelText}"/>
                <TextBox   Grid.Column="1" x:Name="ForzaBindBox" LostFocus="ForzaBind_LostFocus" KeyDown="ForzaBind_KeyDown" VerticalAlignment="Center"
                           ToolTip="Local IP to listen on. 0.0.0.0 = all interfaces (recommended). Use a specific LAN IP only if you want to filter."/>
                <TextBlock Grid.Column="2" Style="{StaticResource HelpText}" Margin="8,0,0,0" VerticalAlignment="Center"
                           Text="0.0.0.0 = listen on every network adapter."/>
            </Grid>
            <CheckBox x:Name="ForzaAlwaysListenCheck" Content="Always listen (use for FH6 day-1 / unrecognized Forza titles)" Click="ForzaAlwaysListen_Changed" Margin="0,4,0,4"
                      ToolTip="Keep the Forza source open even when SimHub doesn't recognize the running game. Lets you use the plugin with FH6 before SimHub adds its game-name detection."/>
            <Grid Margin="0,4,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Status:" Style="{StaticResource LabelText}"/>
                <TextBlock Grid.Column="1" x:Name="ForzaStatusText" Text="(idle)" FontSize="11" Opacity="0.85"/>
            </Grid>
            <!-- Auto-discovered alternate port banner. Shown when the
                 plugin scanned candidate ports and found Forza packets on
                 one we're not bound to. One-click switch + dismiss. -->
            <Border x:Name="ForzaDiscoveryBanner" Background="#3300A8FF" BorderBrush="#00A8FF" BorderThickness="1"
                    CornerRadius="3" Padding="8" Margin="0,4,0,8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ForzaDiscoveryText" FontSize="11" TextWrapping="Wrap"
                               VerticalAlignment="Center" MaxWidth="380"
                               Text="Forza packets detected on a different port."/>
                    <Button x:Name="ForzaDiscoveryAdoptButton" Content="Switch" Width="80" Height="22" FontSize="11"
                            Margin="10,0,4,0" Click="ForzaDiscoveryAdopt_Click"/>
                    <Button x:Name="ForzaDiscoveryDismissButton" Content="Dismiss" Width="80" Height="22" FontSize="11"
                            Click="ForzaDiscoveryDismiss_Click"/>
                </StackPanel>
            </Border>

            <!-- Coexistence forwarder. Forza only sends to one destination, so
                 if the user wants both Trueforce haptics AND SimHub dashboards,
                 they point Forza at us and we relay raw packet bytes verbatim
                 to SimHub. Default off — explicit opt-in keeps un-forwarded
                 packets out of the network when the user doesn't run SimHub. -->
            <Border BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF" Margin="0,4,0,8" Padding="0,8,0,0">
                <StackPanel>
                    <CheckBox x:Name="ForzaForwardEnabledCheck" Content="Also forward to SimHub (for dashboards)" Click="ForzaForwardEnabled_Changed" Margin="0,0,0,4"
                              FontWeight="SemiBold"
                              ToolTip="Enable when you also use SimHub for Forza dashboards. We receive Forza Data Out on our port and re-broadcast each packet verbatim to SimHub on the port below — both apps end up with the same data."/>
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,6" FontSize="11"
                               Text="Find SimHub's Forza port in SimHub: Game → Forza Horizon 5 (or FH6) → telemetry settings, in the UDP port field. Type the same number below — Forza will route through us, then we'll relay to SimHub."/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Forward to host:" Style="{StaticResource LabelText}"/>
                        <TextBox   Grid.Column="1" x:Name="ForzaForwardHostBox" LostFocus="ForzaForwardHost_LostFocus" KeyDown="ForzaForwardHost_KeyDown" VerticalAlignment="Center"
                                   ToolTip="127.0.0.1 if SimHub runs on the same PC. A LAN IP (or hostname) for a separate SimHub host."/>
                        <TextBlock Grid.Column="2" Text="port:" Style="{StaticResource LabelText}" Margin="8,0,0,0"/>
                        <TextBox   Grid.Column="3" x:Name="ForzaForwardPortBox" LostFocus="ForzaForwardPort_LostFocus" KeyDown="ForzaForwardPort_KeyDown" VerticalAlignment="Center" Width="120" HorizontalAlignment="Left"
                                   ToolTip="The port SimHub is listening on for Forza Data Out. Match this to the value in SimHub's Forza game settings."/>
                    </Grid>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Forwarded:" Style="{StaticResource LabelText}"/>
                        <TextBlock Grid.Column="1" x:Name="ForzaForwardStatusText" Text="(disabled)" FontSize="11" Opacity="0.85"/>
                    </Grid>
                </StackPanel>
            </Border>
            <Expander x:Name="ForzaTroubleshootExpander" IsExpanded="False" Margin="0,8,0,16">
                <Expander.Header>
                    <TextBlock Text="Not receiving packets?" FontSize="12"/>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,4" FontSize="11"
                               Text="• MS Store / Game Pass build: Windows network isolation blocks UDP loopback by default. Run CheckNetIsolation.exe LoopbackExempt -a -n=&quot;Microsoft.624F8B84B80_8wekyb3d8bbwe&quot; (or use Fiddler's loopback exemption tool), or set Forza's DATA OUT IP ADDRESS to your LAN IP instead of 127.0.0.1."/>
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,4" FontSize="11"
                               Text="• Steam build: known Playground bug — Forza sends to the gateway IP, not 127.0.0.1. Fix is to set Forza's DATA OUT IP ADDRESS to your machine's LAN IP (e.g. 192.168.x.x) and bind here to 0.0.0.0."/>
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,4" FontSize="11"
                               Text="• Port collision with SimHub or another tool? Pick a different port here, then update Forza's DATA OUT IP PORT to match."/>
                    <TextBlock Style="{StaticResource HelpText}" FontSize="11"
                               Text="• Firewall: Windows Defender may prompt the first time the listener opens — allow it on private/domain networks."/>
                </StackPanel>
            </Expander>
            </StackPanel> <!-- /ForzaSection -->

            <!-- F1 Telemetry (UDP). EA / Codemasters F1 series emits a rich
                 UDP telemetry stream the user enables in Settings → Telemetry
                 Settings. We target F1 25's wire format (PacketFormat=2025);
                 older years receive packets but skip parsing with a clear log
                 line. Recommend 60 Hz Send Rate; warn if the observed rate
                 drops well below that. -->
            <StackPanel x:Name="F1Section" Visibility="Collapsed">
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="F1 telemetry (UDP)" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                Text="In F1 25, open Settings → Telemetry Settings. Set UDP Telemetry to On, UDP IP Address to 127.0.0.1, UDP Port to the port below, UDP Send Rate to 60Hz, and UDP Format to 2025. Enables direct per-wheel slip, KERS deployment, pit limiter, DRS, and surface type."/>
            <CheckBox x:Name="F1EnabledCheck" Content="Enable F1 UDP listener" Click="F1Enabled_Changed" Margin="0,0,0,8"
                      ToolTip="When off, F1 titles fall back to SimHub's universal telemetry (60 Hz, no direct slip, no KERS)."/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Port:" Style="{StaticResource LabelText}"/>
                <TextBox   Grid.Column="1" x:Name="F1PortBox" LostFocus="F1Port_LostFocus" KeyDown="F1Port_KeyDown" VerticalAlignment="Center"
                           ToolTip="Match this in F1's UDP Port. Default 20777."/>
                <TextBlock Grid.Column="2" Style="{StaticResource HelpText}" Margin="8,0,0,0" VerticalAlignment="Center"
                           Text="Restart Trueforce (toggle plugin off+on) after changing."/>
            </Grid>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Bind address:" Style="{StaticResource LabelText}"/>
                <TextBox   Grid.Column="1" x:Name="F1BindBox" LostFocus="F1Bind_LostFocus" KeyDown="F1Bind_KeyDown" VerticalAlignment="Center"
                           ToolTip="0.0.0.0 listens on every interface (recommended)."/>
                <TextBlock Grid.Column="2" Style="{StaticResource HelpText}" Margin="8,0,0,0" VerticalAlignment="Center"
                           Text="0.0.0.0 = listen on every network adapter."/>
            </Grid>
            <CheckBox x:Name="F1AlwaysListenCheck" Content="Always listen (use for unrecognized F1 titles)" Click="F1AlwaysListen_Changed" Margin="0,4,0,4"
                      ToolTip="Keep the F1 source open even when SimHub doesn't recognize the running game."/>
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Status:" Style="{StaticResource LabelText}"/>
                <TextBlock Grid.Column="1" x:Name="F1StatusText" Text="(idle)" FontSize="11" Opacity="0.85"/>
            </Grid>
            <!-- Auto-discovered alternate port banner (F1). Same flow as Forza. -->
            <Border x:Name="F1DiscoveryBanner" Background="#3300A8FF" BorderBrush="#00A8FF" BorderThickness="1"
                    CornerRadius="3" Padding="8" Margin="0,4,0,4" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="F1DiscoveryText" FontSize="11" TextWrapping="Wrap"
                               VerticalAlignment="Center" MaxWidth="380"
                               Text="F1 packets detected on a different port."/>
                    <Button x:Name="F1DiscoveryAdoptButton" Content="Switch" Width="80" Height="22" FontSize="11"
                            Margin="10,0,4,0" Click="F1DiscoveryAdopt_Click"/>
                    <Button x:Name="F1DiscoveryDismissButton" Content="Dismiss" Width="80" Height="22" FontSize="11"
                            Click="F1DiscoveryDismiss_Click"/>
                </StackPanel>
            </Border>
            <!-- Send-rate warning. Shown only when packets are arriving but
                 the observed rate is well below 60 Hz; we recommend the user
                 bump UDP Send Rate in F1's Telemetry Settings. -->
            <Border x:Name="F1RateWarning" Background="#33FFC107" BorderBrush="#FFC107" BorderThickness="1"
                    CornerRadius="3" Padding="8" Margin="0,4,0,8" Visibility="Collapsed">
                <TextBlock x:Name="F1RateWarningText" FontSize="11" TextWrapping="Wrap"
                           Text="UDP Send Rate looks low. Set it to 60Hz in F1 25's Telemetry Settings for the most responsive haptics."/>
            </Border>

            <!-- Coexistence forwarder. F1 only sends to one destination, so
                 if the user wants both Trueforce haptics AND SimHub
                 dashboards, they point F1 at us and we relay raw packet
                 bytes verbatim to SimHub. Default off. -->
            <Border BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF" Margin="0,4,0,8" Padding="0,8,0,0">
                <StackPanel>
                    <CheckBox x:Name="F1ForwardEnabledCheck" Content="Also forward to SimHub (for dashboards)" Click="F1ForwardEnabled_Changed" Margin="0,0,0,4"
                              FontWeight="SemiBold"
                              ToolTip="Enable when you also use SimHub for F1 dashboards. We receive F1 UDP on our port and re-broadcast each packet verbatim to SimHub on the port below."/>
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,6" FontSize="11"
                               Text="Find SimHub's F1 port in SimHub: Game → F1 25 → telemetry settings, in the UDP port field. Type the same number below."/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Forward to host:" Style="{StaticResource LabelText}"/>
                        <TextBox   Grid.Column="1" x:Name="F1ForwardHostBox" LostFocus="F1ForwardHost_LostFocus" KeyDown="F1ForwardHost_KeyDown" VerticalAlignment="Center"
                                   ToolTip="127.0.0.1 if SimHub runs on the same PC. A LAN IP (or hostname) for a separate SimHub host."/>
                        <TextBlock Grid.Column="2" Text="port:" Style="{StaticResource LabelText}" Margin="8,0,0,0"/>
                        <TextBox   Grid.Column="3" x:Name="F1ForwardPortBox" LostFocus="F1ForwardPort_LostFocus" KeyDown="F1ForwardPort_KeyDown" VerticalAlignment="Center" Width="120" HorizontalAlignment="Left"
                                   ToolTip="The port SimHub is listening on for F1 UDP telemetry. Match this to the value in SimHub's F1 25 game settings."/>
                    </Grid>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Forwarded:" Style="{StaticResource LabelText}"/>
                        <TextBlock Grid.Column="1" x:Name="F1ForwardStatusText" Text="(disabled)" FontSize="11" Opacity="0.85"/>
                    </Grid>
                </StackPanel>
            </Border>
            </StackPanel> <!-- /F1Section -->

            <!-- Diagnostics + Live activity. Sit between game-config sections
                 (above) and preset/sharing/support sections (below). Both are
                 collapsed by default — only opened when troubleshooting or
                 wanting to watch effect activity meters. -->
            <Expander x:Name="DiagnosticsExpander" IsExpanded="False" Margin="0,0,0,4">
                <Expander.Header>
                    <TextBlock Text="Diagnostics" FontSize="13" FontWeight="SemiBold"/>
                </Expander.Header>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Wheel:" Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="WheelText" Text="(checking...)"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Stream:" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StreamText" Text="(checking...)" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="FFB pass-through:" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="FfbTapText" Text="(checking...)" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Telemetry:" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TelemetrySourceText" Text="(checking...)" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Active sources:" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="VoicesText" Text="0" Margin="0,4,0,0"/>
                </Grid>
            </Expander>

            <Expander x:Name="LiveActivityExpander" IsExpanded="False" Margin="0,0,0,16">
                <Expander.Header>
                    <TextBlock Text="Live activity" FontWeight="SemiBold" FontSize="13"/>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Engine pulse:" Style="{StaticResource LabelText}"/>
                        <Border Grid.Column="1" x:Name="EngineMeterTrack" Height="14" Background="#22FFFFFF" CornerRadius="2" HorizontalAlignment="Stretch">
                            <Border x:Name="EngineMeterFill" HorizontalAlignment="Left" Background="#4CAF50" CornerRadius="2" Width="0"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Audio capture:" Style="{StaticResource LabelText}"/>
                        <Border Grid.Column="1" x:Name="AudioCaptureMeterTrack" Height="14" Background="#22FFFFFF" CornerRadius="2" HorizontalAlignment="Stretch">
                            <Border x:Name="AudioCaptureMeterFill" HorizontalAlignment="Left" Background="#66BB6A" CornerRadius="2" Width="0"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Road bumps:" Style="{StaticResource LabelText}"/>
                        <Border Grid.Column="1" x:Name="BumpsMeterTrack" Height="14" Background="#22FFFFFF" CornerRadius="2" HorizontalAlignment="Stretch">
                            <Border x:Name="BumpsMeterFill" HorizontalAlignment="Left" Background="#FFA726" CornerRadius="2" Width="0"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Traction loss:" Style="{StaticResource LabelText}"/>
                        <Border Grid.Column="1" x:Name="TractionMeterTrack" Height="14" Background="#22FFFFFF" CornerRadius="2" HorizontalAlignment="Stretch">
                            <Border x:Name="TractionMeterFill" HorizontalAlignment="Left" Background="#EF5350" CornerRadius="2" Width="0"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Gear shift:" Style="{StaticResource LabelText}"/>
                        <Border Grid.Column="1" x:Name="GearMeterTrack" Height="14" Background="#22FFFFFF" CornerRadius="2" HorizontalAlignment="Stretch">
                            <Border x:Name="GearMeterFill" HorizontalAlignment="Left" Background="#42A5F5" CornerRadius="2" Width="0"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ABS:" Style="{StaticResource LabelText}"/>
                        <Border Grid.Column="1" x:Name="AbsMeterTrack" Height="14" Background="#22FFFFFF" CornerRadius="2" HorizontalAlignment="Stretch">
                            <Border x:Name="AbsMeterFill" HorizontalAlignment="Left" Background="#AB47BC" CornerRadius="2" Width="0"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Pit limiter:" Style="{StaticResource LabelText}"/>
                        <Border Grid.Column="1" x:Name="PitLimiterMeterTrack" Height="14" Background="#22FFFFFF" CornerRadius="2" HorizontalAlignment="Stretch">
                            <Border x:Name="PitLimiterMeterFill" HorizontalAlignment="Left" Background="#FF7043" CornerRadius="2" Width="0"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="DRS:" Style="{StaticResource LabelText}"/>
                        <Border Grid.Column="1" x:Name="DrsMeterTrack" Height="14" Background="#22FFFFFF" CornerRadius="2" HorizontalAlignment="Stretch">
                            <Border x:Name="DrsMeterFill" HorizontalAlignment="Left" Background="#26C6DA" CornerRadius="2" Width="0"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ducking depth:" Style="{StaticResource LabelText}"/>
                        <Border Grid.Column="1" x:Name="DuckMeterTrack" Height="14" Background="#22FFFFFF" CornerRadius="2" HorizontalAlignment="Stretch">
                            <Border x:Name="DuckMeterFill" HorizontalAlignment="Left" Background="#9E9E9E" CornerRadius="2" Width="0"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Presets. The preset library, default-binding, and per-game
                 defaults. The active preset dropdown + ★ Save preset button
                 at the very top of the panel handles the day-to-day cases. -->
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="Presets" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                Text="A preset is a named snapshot of your master tuning + every per-car override. Live tuning auto-saves to disk, but never changes the named preset on its own — the '★ unsaved' indicator next to the active preset means tuning has drifted from the saved snapshot. Click Save preset to commit, Save as… for a new name."/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="PresetCombo" SelectionChanged="PresetCombo_Changed" VerticalAlignment="Center"/>
                <Button   Grid.Column="1" x:Name="ApplyPresetButton" Content="Apply" Width="70" Height="28" Margin="8,0,0,0" Click="ApplyPreset_Click"
                          ToolTip="Load the selected preset, replacing current tuning. Confirms first if you have unsaved changes."/>
                <Button   Grid.Column="2" x:Name="SavePresetButton" Content="Save preset"
                          Style="{StaticResource SaveAllPresetButton}" Click="SavePreset_Click"
                          ToolTip="Overwrite the active preset with your current tuning. Glows amber when changes are unsaved."/>
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button x:Name="SaveAsPresetButton" Content="Save as new..." Width="110" Height="24" FontSize="11" Margin="0,0,6,0" Click="SaveAsPreset_Click"
                        ToolTip="Save current tuning under a new preset name (doesn't overwrite the active one)."/>
                <Button x:Name="DeletePresetButton" Content="Delete" Width="70" Height="24" FontSize="11" Click="DeletePreset_Click"
                        ToolTip="Delete the selected preset from the library."/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="SetDefaultButton"   Content="Set as default for this game" Width="220" Height="24" FontSize="11" Margin="0,0,6,0" Click="SetDefault_Click"
                        ToolTip="When this game launches, auto-load the selected preset."/>
                <Button x:Name="ClearDefaultButton" Content="Clear default" Width="100" Height="24" FontSize="11" Click="ClearDefault_Click"
                        ToolTip="Remove the auto-load binding for this game."/>
            </StackPanel>
            <!-- Backup & sync. Promoted to its own top-level section since
                 sharing presets / migrating settings between machines is its
                 own flow, distinct from preset library management. -->
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="Backup &amp; sync" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8"
                       Text="Share single presets, per-car overrides, or your full Trueforce config as JSON files."/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button x:Name="ExportPresetButton" Content="Export preset..." Width="160" Height="26" Margin="0,0,6,0" Click="ExportPreset_Click"
                        ToolTip="Save the selected preset to a shareable JSON file."/>
                <Button x:Name="ImportPresetButton" Content="Import preset..." Width="160" Height="26" Click="ImportPreset_Click"
                        ToolTip="Load a preset file into your library."/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button x:Name="ExportCarPresetButton" Content="Export car preset..." Width="180" Height="26" Margin="0,0,6,0" Click="ExportCarPreset_Click"
                        ToolTip="Save the active car's settings as a shareable JSON file."/>
                <Button x:Name="ImportCarPresetButton" Content="Import car preset..." Width="180" Height="26" Click="ImportCarPreset_Click"
                        ToolTip="Load a car preset file. Stored under its car id; applied if it matches the current car."/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button x:Name="ExportPackButton" Content="Export pack..." Width="180" Height="26" Margin="0,0,6,0" Click="ExportPack_Click"
                        ToolTip="Bundle multiple game presets and car presets into a single .tfpack zip for sharing."/>
                <Button x:Name="ImportPackButton" Content="Import pack..." Width="180" Height="26" Click="ImportPack_Click"
                        ToolTip="Import every game preset and car preset from a .tfpack zip."/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button x:Name="ExportButton" Content="Export all settings..." Width="180" Height="26" Margin="0,0,6,0" Click="Export_Click"
                        ToolTip="Export master, audio, every effect, and all per-car overrides as one JSON file."/>
                <Button x:Name="ImportButton" Content="Import all settings..." Width="180" Height="26" Click="Import_Click"
                        ToolTip="Replace all current Trueforce settings from a JSON file."/>
            </StackPanel>

            <!-- Support development -->
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="Support development" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,10" FontSize="12"
                Text="If this plugin made your wheel feel better, a tip is appreciated but never expected. Cheers."/>
            <!-- Custom-templated button: SimHub's theme overrides Button.Background
                 on stock buttons. A full ControlTemplate replaces the visual tree
                 so the Ko-fi brand red survives intact. -->
            <Button x:Name="DonateButton" Click="Donate_Click" Cursor="Hand"
                    HorizontalAlignment="Left" Width="200" Height="44" Margin="0,0,0,8">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DonateBd" Background="#FF5E5B" CornerRadius="8" BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.35"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Canvas Grid.Column="0" Width="22" Height="22" Margin="14,0,8,0" VerticalAlignment="Center">
                                    <Path Stroke="White" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M 7,2 C 9,4 5,6 7,8"/>
                                    <Path Stroke="White" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M 12,2 C 14,4 10,6 12,8"/>
                                    <Path Fill="White" Data="M 3,10 L 14,10 L 13,18 C 13,19.5 12,20 10.5,20 L 6.5,20 C 5,20 4,19.5 4,18 Z"/>
                                    <Path Stroke="White" StrokeThickness="1.6" Fill="Transparent"
                                          Data="M 14,12 C 18,12 18,17 14,17"/>
                                </Canvas>
                                <TextBlock Grid.Column="1" Text="Support on Ko-fi"
                                           Foreground="White" FontWeight="Bold" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DonateBd" Property="Background" Value="#E54E4B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DonateBd" Property="Background" Value="#CC3F3D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock Text="ko-fi.com/mhytee" FontSize="11" Opacity="0.5" Margin="0,0,0,8"/>

            <!-- Report-issue + repo link: separate from cylinder reporting; this
                 is for everything else (bugs, feature requests, weird behavior). -->
            <Border Style="{StaticResource SectionHeaderBorder}" Margin="0,16,0,0"><TextBlock Text="Feedback" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                Text="Found a bug, weird behavior, or have a feature request? Open an issue on GitHub."/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="ReportIssueButton" Content="Report an issue…" Width="160" Height="26"
                        Click="ReportIssue_Click" Margin="0,0,8,0"
                        ToolTip="Opens a new GitHub issue. Pre-fills plugin version and active game so you don't have to type it."/>
                <Button x:Name="OpenRepoButton" Content="Open project on GitHub" Width="180" Height="26"
                        Click="OpenRepo_Click"
                        ToolTip="github.com/Mhytee/Trueforce-For-All"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
