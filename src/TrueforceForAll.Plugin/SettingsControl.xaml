<UserControl x:Class="TrueforceForAll.Plugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignHeight="900" d:DesignWidth="700">
    <UserControl.Resources>
        <Style x:Key="SectionHeaderBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,0,0,8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="HelpText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style x:Key="OverrideBadge" TargetType="TextBlock">
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FFD54F"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Text" Value="★ car override"/>
        </Style>
        <!-- Per-effect "not exposed by this game" badge. Surfaces in an
             effect's header when the active game's telemetry source doesn't
             expose the signal the effect needs (e.g. Forza Data Out doesn't
             include ABS pump activity). Muted grey so it reads as info,
             not a warning; section stays interactive so users can still
             tune values for other games. -->
        <Style x:Key="UnsupportedBadge" TargetType="TextBlock">
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
        <!-- Per-effect "NEW" badge. Surfaces in an effect's expander header
             until the user has acknowledged it (expanded the section, or
             changed any of its values). Pre-seeded as already-seen on fresh
             install / pre-feature upgrade so existing users don't get a wall
             of badges for effects they've already been using. Code-behind
             toggles Visibility from RefreshNewBadges. -->
        <Style x:Key="NewEffectBadge" TargetType="Border">
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="#3D8B40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="ToolTip" Value="Added in a recent update. Disappears once you expand the section or change a value."/>
        </Style>
        <!-- Custom-templated effect-header buttons. SimHub's stock theme greys
             every Button.Background; a full ControlTemplate replaces the visual
             tree so our accent colors survive. Test = always visible blue.
             Save = only visible when that section is dirty (toggled from
             code-behind), amber to draw attention to the unsaved state. -->
        <Style x:Key="EffectTestButton" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="14,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#3A6BBE" CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2F5DA6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#234A88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#555"/>
                                <Setter Property="Foreground" Value="#AAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EffectRevertButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ToolTip" Value="Discard unsaved changes (revert to the active preset's saved values)."/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#6E6E6E" CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5C5C5C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Main Save preset button. Saves everything (whole snapshot).
             Visually adapts to dirty state via Tag: when code-behind sets
             Tag="dirty", amber accent + larger; when Tag is empty, grey
             subtle. Content is also flipped between "Save preset" and
             "★ Save all changes" from code-behind. -->
        <Style x:Key="SaveAllPresetButton" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#555" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="dirty">
                                <Setter TargetName="Bd" Property="Background" Value="#FFB300"/>
                                <Setter Property="Foreground" Value="#1A1A1A"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#666"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="dirty"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#FFA000"/>
                            </MultiTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsPressed" Value="True"/>
                                    <Condition Property="Tag" Value="dirty"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#E69100"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Flat link-style button for tertiary preset/admin actions
             (Save as new, Delete, Manage, Set/Clear default). No border or
             fill so the row reads as "extra actions" instead of competing
             with the primary Apply / Save preset buttons above. -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="Txt"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="Txt" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EffectSaveButton" TargetType="Button">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="ToolTip" Value="Unsaved changes. Click to save (per-car or to preset)."/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#FFB300" CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFA000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E69100"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Compact amber "Save all" buttons that live in the header next to
             the game / car preset pickers. Shown only when that target has
             unsaved tuning; each saves every changed section at once to its
             own target (game default vs this car). -->
        <Style x:Key="HeaderSaveAllButton" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="14,2"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#C8860B" CornerRadius="8" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E09B0E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A8720A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Trueforce For All" FontSize="22" FontWeight="Bold"/>
                <TextBlock x:Name="HeaderVersionText" Text="" FontSize="13" Opacity="0.5"
                           VerticalAlignment="Bottom" Margin="8,0,0,3"/>
                <!-- "Check for updates" link. Hidden when an update is available;
                     the UpdateAvailableButton takes its place. -->
                <Button x:Name="CheckForUpdatesButton" Content="Check for updates"
                        Style="{StaticResource LinkButton}" Margin="12,0,0,3"
                        VerticalAlignment="Bottom"
                        Click="CheckForUpdatesButton_Click"
                        ToolTip="Re-poll GitHub for a newer release. The plugin also checks once automatically on startup."/>
                <TextBlock x:Name="CheckForUpdatesStatus" Text="" FontSize="11" Opacity="0.6"
                           VerticalAlignment="Bottom" Margin="8,0,0,3"/>
                <!-- Prominent inline CTA. Hidden until UpdateChecker confirms a
                     newer GitHub release; visibility + label are driven from
                     RefreshFromPlugin. Click opens the same modal that the
                     legacy banner used to open. -->
                <Button x:Name="UpdateAvailableButton" Visibility="Collapsed"
                        Margin="12,0,0,3" VerticalAlignment="Bottom"
                        Padding="10,4,10,4" FontSize="12" FontWeight="SemiBold"
                        Background="#FFB300" Foreground="#222" BorderBrush="#FFA000"
                        BorderThickness="1" Cursor="Hand"
                        Click="UpdateAvailableButton_Click"
                        ToolTip="Open the update dialog (release notes + Update now button).">
                    <TextBlock x:Name="UpdateAvailableButtonText" Text="Update available"/>
                </Button>
            </StackPanel>
            <TextBlock Text="Brings Trueforce-style haptics to any SimHub-enabled game. Unofficial reverse-engineered implementation of Logitech's Trueforce protocol, not affiliated with Logitech. Supports G PRO / RS50 / G923 wheels."
                       FontSize="13" Opacity="0.7" Margin="0,0,0,12" TextWrapping="Wrap"/>

            <!-- "What's new" banner. Shown when the running build's version
                 is ahead of Settings.LastSeenVersion (i.e. the user just
                 upgraded). Click opens a modal listing every changelog
                 entry newer than their stamp; dismissing the modal stamps
                 LastSeenVersion to the current build. Hidden after dismiss. -->
            <Border x:Name="WhatsNewBanner" Visibility="Collapsed"
                    Background="#3D8B40" CornerRadius="4" Padding="10,8,10,8" Margin="0,0,0,10"
                    Cursor="Hand" MouseLeftButtonUp="WhatsNewBanner_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="WhatsNewBannerText" Foreground="White"
                               FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"
                               Text="What's new"/>
                    <TextBlock Grid.Column="1" Foreground="White" Opacity="0.85"
                               FontSize="12" VerticalAlignment="Center" Text="View →"/>
                </Grid>
            </Border>

            <!-- "Spread the word" banner. One-and-done. Surfaces only after
                 the user has banked real working seat time
                 (Settings.ActiveStreamingSeconds past the threshold) so it
                 never lands mid-setup. Clicking copies a short blurb and
                 opens the project page; the x declines. Either path latches
                 ShareCtaDismissed so it never shows again. -->
            <Border x:Name="ShareCtaBanner" Visibility="Collapsed"
                    Background="#5B4B9E" CornerRadius="4" Padding="10,8,10,8" Margin="0,0,0,10"
                    Cursor="Hand" MouseLeftButtonUp="ShareCtaBanner_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Foreground="White"
                               FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Text="Wheel feeling alive in a game that never had Trueforce? Help another sim racer find TF4ALL."/>
                    <TextBlock Grid.Column="1" Foreground="White" Opacity="0.85"
                               FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"
                               Text="Share →"/>
                    <Button Grid.Column="2" x:Name="ShareCtaDismiss"
                            Content="✕" Width="22" Height="22" Margin="10,0,0,0"
                            Click="ShareCtaDismiss_Click"
                            Background="Transparent" Foreground="White"
                            BorderBrush="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Don't show this again"/>
                </Grid>
            </Border>

            <!-- Experimental FFB success prompt. Shows once when experimental
                 FFB detection was load-bearing in getting capture working
                 (ShouldShowExperimentalSuccessReport). Clicking opens a
                 prefilled GitHub Discussions post in the "FFB compatibility
                 reports" category (wheel VID/PID + capture fingerprint already
                 filled in) so we learn which wheels to graduate out of
                 experimental; the x declines. Either path latches
                 ExperimentalSuccessReportDismissed. -->
            <Border x:Name="ExperimentalSuccessBanner" Visibility="Collapsed"
                    Background="#2E7D52" CornerRadius="4" Padding="10,8,10,8" Margin="0,0,0,10">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Foreground="White"
                                   FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="Experimental FFB detection started capturing your wheel. Is your force feedback working now?"/>
                        <Button Grid.Column="1" x:Name="ExperimentalSuccessDismiss"
                                Content="✕" Width="22" Height="22" Margin="10,0,0,0" VerticalAlignment="Top"
                                Click="ExperimentalSuccessDismiss_Click"
                                Background="Transparent" Foreground="White"
                                BorderBrush="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="Don't show this again"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="ExperimentalSuccessYes" Content="Yes, it's working"
                                Padding="12,3" Cursor="Hand" Click="ExperimentalSuccessYes_Click"
                                ToolTip="Opens a prefilled compatibility report (wheel ID + details already filled in)."/>
                        <Button x:Name="ExperimentalSuccessNo" Content="No, still no FFB"
                                Padding="12,3" Margin="8,0,0,0" Cursor="Hand" Click="ExperimentalSuccessNo_Click"
                                ToolTip="Opens the diagnostics / troubleshooter."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Auto-tuned ring buffer notice. Surfaces when the auto-
                 ratchet bumps a ring size to recover from sustained
                 dropouts. One banner consolidates every bump in the
                 current session: the "from" caps stay pinned to the
                 sizes that were active when the banner first appeared,
                 the "to" caps update to the latest after each bump.
                 Inline and non-modal (never grabs foreground) per user
                 feedback that the old centered Window was disruptive. -->
            <Border x:Name="RatchetNoticeBanner" Visibility="Collapsed"
                    Background="#3A6BBE" CornerRadius="4" Padding="12,8,12,8" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="13"
                                   Text="Auto-tuned ring buffer"/>
                        <TextBlock x:Name="RatchetNoticeDetail" Foreground="White" FontSize="11"
                                   Opacity="0.9" Margin="0,2,0,0" TextWrapping="Wrap" Text=""/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="RatchetNoticeRevert"
                            Content="Revert" Padding="10,3" Margin="10,0,0,0"
                            VerticalAlignment="Center" Cursor="Hand"
                            Click="RatchetNoticeRevert_Click"
                            ToolTip="Drop the ring(s) back to the size(s) they were at before this session's auto-bumps. Trades dropout resilience for tighter latency."/>
                    <Button Grid.Column="2" x:Name="RatchetNoticeDismiss"
                            Content="✕" Width="22" Height="22" Margin="6,0,0,0"
                            Click="RatchetNoticeDismiss_Click"
                            Background="Transparent" Foreground="White"
                            BorderBrush="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Dismiss"/>
                </Grid>
            </Border>

            <!-- Offline-edit mode banner. Visible when the user clicked Edit
                 on a preset row in the Manage Presets dialog. While shown,
                 the plugin holds back the auto-apply-game-default path so a
                 background game launch doesn't clobber in-progress edits.
                 Built-ins use the same banner with the Save button relabeled
                 "Save as new…" so the fork behavior is obvious from the
                 button itself, no separate subtitle needed. -->
            <Border x:Name="OfflineEditBanner" Visibility="Collapsed"
                    Background="#3A6BBE" CornerRadius="4" Padding="12,8,12,8" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="OfflineEditTitle" Foreground="White" FontWeight="SemiBold"
                               FontSize="13" VerticalAlignment="Center" Text="Editing preset"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                        <Button x:Name="OfflineEditSaveBtn" Content="Save" Width="78" Height="26"
                                Margin="0,0,6,0" Click="OfflineEditSave_Click"
                                ToolTip="Write your edits back into the preset being edited."/>
                        <Button x:Name="OfflineEditSaveAsBtn" Content="Save as new…" Width="110" Height="26"
                                Margin="0,0,6,0" Click="OfflineEditSaveAs_Click"
                                ToolTip="Save your edits under a new preset name and exit edit mode."/>
                        <Button x:Name="OfflineEditDiscardBtn" Content="Discard" Width="80" Height="26"
                                Click="OfflineEditDiscard_Click"
                                ToolTip="Throw away your edits and restore the state you had before entering edit mode."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Header strip: master toggle + at-a-glance context.
                 Just Game / Car / Preset and a single status pill. Verbose
                 wheel/stream/telemetry strings live in Diagnostics. -->
            <Border Background="#22FFFFFF" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <CheckBox x:Name="PluginEnabledCheck" FontSize="14" FontWeight="SemiBold"
                              Content="Plugin enabled"
                              Checked="PluginEnabled_Changed" Unchecked="PluginEnabled_Changed"/>
                    <TextBlock x:Name="PluginEnabledHint" FontSize="11" Opacity="0.6"
                               TextWrapping="Wrap" Margin="22,4,0,10"
                               Text="Auto-remembered per game. Disable for games with native Trueforce (e.g. iRacing) so this plugin yields the wheel."/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Game"   FontSize="12" Opacity="0.6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="HeaderGameText"   Text="(none)" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Car"    FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="HeaderCarText"    Text="(none)" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Game preset" FontSize="12" Opacity="0.6" Margin="0,3,0,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,3,0,0">
                            <ComboBox x:Name="HeaderPresetCombo" SelectionChanged="HeaderPresetCombo_Changed"
                                      MinWidth="220" MaxWidth="340" VerticalAlignment="Center"
                                      MaxDropDownHeight="420" IsTextSearchEnabled="True"
                                      ToolTip="The active game preset. Start typing to jump to a name. Confirms first if you have unsaved tuning."/>
                            <Button x:Name="HeaderGameSaveAllBtn" Content="★ Save all"
                                    Style="{StaticResource HeaderSaveAllButton}" Click="HeaderGameSaveAll_Click"
                                    ToolTip="You have unsaved tuning. Save every changed section at once. Opens a chooser to save to the game default, this car, or both."/>
                            <!-- Conditional: only shown when the active preset is
                                 not already this game's auto-load default (see
                                 UpdateSetDefaultButton). Replaces the old bottom
                                 'Set as default for this game' button. -->
                            <Button x:Name="HeaderSetDefaultBtn" Content="Set as default" Visibility="Collapsed"
                                    Height="24" Padding="10,0" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"
                                    Click="HeaderSetDefault_Click"
                                    ToolTip="Auto-load this preset whenever this game launches. Shown only when the active preset isn't already this game's default."/>
                            <!-- Conditional: shown alongside ★ Save all (i.e.
                                 when there's unsaved tuning), see
                                 UpdateGlobalDirtyFromEffects. -->
                            <Button x:Name="HeaderSaveAsNewBtn" Content="Save as new…" Visibility="Collapsed"
                                    Style="{StaticResource LinkButton}" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Click="SaveAsPreset_Click"
                                    ToolTip="Save current tuning under a new preset name (doesn't overwrite the active one)."/>
                        </StackPanel>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Car preset" FontSize="12" Opacity="0.6" Margin="0,3,0,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,3,0,0">
                            <ComboBox x:Name="HeaderCarPresetCombo" SelectionChanged="HeaderCarPresetCombo_Changed"
                                      MinWidth="220" MaxWidth="340"
                                      VerticalAlignment="Center"
                                      MaxDropDownHeight="420" IsTextSearchEnabled="True"
                                      ToolTip="The preset for the current car. Pick this car's preset, or another car's to load its tuning onto the current car. Save in the Active car section saves it to this car. Confirms first if you have unsaved tuning."/>
                            <Button x:Name="HeaderCarSaveAllBtn" Content="★ Save all"
                                    Style="{StaticResource HeaderSaveAllButton}" Click="HeaderCarSaveAll_Click"
                                    ToolTip="You have unsaved tuning for this car. Save every changed section at once. Opens a chooser that leads with this car (or the game default, or both)."/>
                            <!-- Conditional: shown alongside the car ★ Save all
                                 (i.e. when this car has unsaved tuning), see
                                 UpdateGlobalDirtyFromEffects. -->
                            <Button x:Name="HeaderCarSaveAsNewBtn" Content="Save as new…" Visibility="Collapsed"
                                    Style="{StaticResource LinkButton}" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Click="CarSaveAsNew_Click"
                                    ToolTip="Save this car's current tuning as a new car preset (doesn't overwrite the active one)."/>
                        </StackPanel>
                    </Grid>

                    <!-- Status pill row: status badge (+ optional gold "Enhanced
                         N Hz" hype badge) on the left; Manage presets… shares the
                         line on the right to save a row of vertical space. -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="StatusPill" CornerRadius="10" Padding="10,3" Background="#3D8B40">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="StatusPillDot" Width="8" Height="8" Fill="#A5D6A7" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="StatusPillText" Text="Idle" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="EnhancedBadge" CornerRadius="10" Padding="10,3" Background="#FFB300"
                                    Margin="6,0,0,0" Visibility="Collapsed"
                                    ToolTip="Per-game enhanced telemetry source. Higher rate and more physics signals than the standard SimHub data pipe.">
                                <TextBlock x:Name="EnhancedBadgeText" Text="✨ Enhanced" Foreground="#1A1A1A" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <!-- Full preset library entry point. Shares the status
                             row to keep all preset handling unified in the card
                             (pick + save inline above) without spending an extra
                             line; the old standalone Presets section was removed. -->
                        <Button x:Name="ManagePresetsButton" Grid.Column="1" Content="Manage presets…"
                                VerticalAlignment="Center" Height="26" Padding="12,0"
                                Click="ManagePresetsButton_Click"
                                ToolTip="Open the full library: rename, duplicate, export, delete, or re-bind defaults for any game preset, car preset, or custom engine. Works even when no game or car is loaded."/>
                    </Grid>

                    <!-- Logitech G HUB warning banner. G HUB claims the wheel's
                         HID interface; while it's running we can't talk to the
                         wheel. Surfaced as a dedicated red banner (separate from
                         the WheelQuietDiagnostic below) so the user sees it even
                         when other issues coexist (e.g., master gain also at 0).
                         Hidden when G HUB isn't detected. -->
                    <Border x:Name="GHubWarningBox" Visibility="Collapsed"
                            Background="#D32F2F" CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Foreground="White" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"
                                       Text="Logitech G HUB is running. Close it, then reload the Trueforce plugin from SimHub's Plugins page (G HUB claims the wheel and blocks Trueforce)."/>
                        </StackPanel>
                    </Border>

                    <!-- Admin/elevation warning. SimHub needs to run as
                         administrator for reliable force feedback: USBPcap's
                         bus capture (which mirrors the game's FFB) can fail
                         silently without it, and some games only pass FFB
                         through when elevated. Shown whenever SimHub isn't
                         elevated; treated as effectively required. -->
                    <Border x:Name="AdminWarningBox" Visibility="Collapsed"
                            Background="#D32F2F" CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Foreground="White" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"
                                       Text="SimHub is not running as administrator. This is required for reliable force feedback (the USB capture that mirrors the game's FFB can fail without it). Easiest fix: turn on 'Run as administrator' in SimHub's own Settings, then restart SimHub."/>
                        </StackPanel>
                    </Border>

                    <!-- Why-is-my-wheel-quiet diagnostic. Shown only when the
                         plugin detects a likely reason output is silent
                         (master switch off, wheel disconnected, no telemetry,
                         all effects disabled, ducker swallowing everything,
                         etc). Hidden when healthy. Yellow background so it's
                         visually distinct from regular status text. -->
                    <Border x:Name="WheelQuietDiagnosticBox" Visibility="Collapsed"
                            Background="#FFC107" CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="14" Foreground="#222" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="WheelQuietDiagnosticText" Foreground="#222"
                                       FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"
                                       Text=""/>
                        </StackPanel>
                    </Border>

                    <!-- FFB-tap divergence banner. HID found the wheel (so
                         Trueforce effects play) but USBPcap couldn't find it
                         on the bus, so the game's native force feedback gets
                         clobbered. Surfaces the manual picker right where the
                         user notices the problem instead of hiding it inside
                         Diagnostics. Hidden once the user picks a device. -->
                    <Border x:Name="FfbTapPickerBanner" Visibility="Collapsed"
                            Background="#FF8F00" CornerRadius="4" Padding="10,8" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⚠" FontSize="14" Foreground="#222"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Foreground="#222"
                                       FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"
                                       Text="Your wheel is connected, but FFB pass-through can't find it on the USB bus, so your game's force feedback may feel wrong or be silenced. This is most often fixed by restarting your computer (USBPcap's capture driver only loads at boot, especially right after it was installed). If a reboot doesn't fix it, pick the wheel manually."/>
                            <Button Grid.Column="2" x:Name="FfbTapPickerBannerButton"
                                    Content="Pick device manually..."
                                    Width="170" Height="28" Margin="10,0,0,0"
                                    Click="UsbPcapPickDevice_Click"
                                    Background="#222" Foreground="#FFC107"
                                    BorderBrush="#222" BorderThickness="1"/>
                        </Grid>
                    </Border>

                    <!-- Unverified-wheel notice. Detected PID is supported by
                         inference (shared HID++ family) but not hardware-tested.
                         Asks the user to report the one failure mode we can't
                         rule out: Trueforce effects play but game FFB is silent
                         (init/handshake divergence). Blue = informational,
                         not an error. Hidden for confirmed wheels (all supported
                         PIDs today, so this banner is currently never shown). -->
                    <Border x:Name="UnverifiedWheelBanner" Visibility="Collapsed"
                            Background="#1565C0" CornerRadius="4" Padding="10,8" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ⓘ" FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="UnverifiedWheelText" Foreground="White"
                                       FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"
                                       Text=""/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Master -->
            <Border Style="{StaticResource SectionHeaderBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Master" Style="{StaticResource SectionHeaderText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="MasterRevertBtn" Content="↶" Tag="Master" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                    <Button Grid.Column="2" x:Name="MasterSaveBtn"   Content="Save…" Tag="Master" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                </Grid>
            </Border>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Master gain:" Style="{StaticResource LabelText}"/>
                <Slider     Grid.Column="1" x:Name="MasterGainSlider"
                            Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                            TickFrequency="0.25" ValueChanged="MasterGainSlider_ValueChanged" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="MasterGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
            </Grid>
            <!-- Promoted FFB pass-through toggle. Visible only when the active
                 game ships native Trueforce (see ActiveGameIsNativeTrueforce).
                 For every other game the same toggle lives in Advanced
                 settings, where it almost never needs touching. -->
            <StackPanel x:Name="FfbSkipPassthroughPromotedPanel" Visibility="Collapsed">
                <CheckBox x:Name="FfbSkipPassthroughPromotedCheck" Content="Skip FFB pass-through (native Trueforce games)"
                          Margin="0,0,0,2" Checked="FfbSkipPassthroughPromoted_Changed" Unchecked="FfbSkipPassthroughPromoted_Changed"/>
                <TextBlock Style="{StaticResource HelpText}" Margin="22,0,0,12"
                           Text="This game ships native Trueforce. Enable to let the game drive the wheel directly while our effects play on top. Disable only if you prefer to mirror the game's FFB through our capture (rarely needed)."/>
            </StackPanel>

            <!-- FFB pass-through controls. Greyed when SkipFfbPassthrough is on. -->
            <StackPanel x:Name="FfbPassthroughControls">
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FFB scale:" Style="{StaticResource LabelText}"/>
                    <Slider     Grid.Column="1" x:Name="FfbScaleSlider"
                                Minimum="0" Maximum="1.5" SmallChange="0.05" LargeChange="0.1"
                                TickFrequency="0.25" ValueChanged="FfbScaleSlider_ValueChanged" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" x:Name="FfbScaleText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FFB smooth (ms):" Style="{StaticResource LabelText}"
                               ToolTip="Low-pass on AC's incoming FFB target. AC sends FFB updates every ~7 ms; smoothing converts the staircase into a ramp. Higher = smoother feel but more lag. Lower = tighter response but possible faint mechanical tick. 0 = pure passthrough (tightest response)."/>
                    <Slider     Grid.Column="1" x:Name="FfbSmoothSlider"
                                Minimum="0" Maximum="10" SmallChange="0.5" LargeChange="1"
                                TickFrequency="1" ValueChanged="FfbSmoothSlider_ValueChanged" VerticalAlignment="Center"
                                ToolTip="Low-pass on AC's incoming FFB target. AC sends FFB updates every ~7 ms; smoothing converts the staircase into a ramp. Higher = smoother feel but more lag. Lower = tighter response but possible faint mechanical tick. 0 = pure passthrough (tightest response)."/>
                    <TextBlock Grid.Column="2" x:Name="FfbSmoothText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.0"/>
                </Grid>
                <!-- Invert FFB sign. Default on (correct for the common games
                     on the wheels we've tested), but NOT universal: RaceRoom
                     and some wheels report the opposite convention, so this
                     stays a user toggle. Uncheck if forces feel reversed. -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="1" x:Name="FfbInvertCheck" Content="Invert FFB sign (uncheck if forces feel reversed)"
                              VerticalAlignment="Center" Checked="FfbInvert_Changed" Unchecked="FfbInvert_Changed"
                              ToolTip="Flips the direction of the game's force feedback sent to the wheel. On by default. If your wheel pushes the wrong way (e.g. forces feel reversed in RaceRoom), uncheck this."/>
                </Grid>
                <!-- Stationary spring: synthesizes a parked-car centering
                     force the game itself doesn't send (a stationary tire has
                     ~0 self-aligning torque). Deficit-fill + speed-fade, so it
                     can't fight the game's FFB. Uses the game's reported
                     steering whenever it provides one (AC / Forza), and falls
                     back to the wheel's physical position (WheelSteeringReader)
                     for any game that doesn't report steering via telemetry, so
                     it works in any game; always off for iRacing (MAIRA already
                     weights it). Forza's steering is coarse so the consumer
                     smooths it. -->
                <Grid Margin="0,8,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="1" x:Name="StationarySpringCheck"
                              Content="Stationary spring (adds parked-car wheel weight)"
                              VerticalAlignment="Center"
                              Checked="StationarySpring_Changed" Unchecked="StationarySpring_Changed"
                              ToolTip="A parked car sends almost no force feedback, so the wheel feels limp. This adds a centering weight that fades out as you start moving and never fights the game's own FFB. It works in any game, and is ignored for iRacing (MAIRA already weights the wheel)."/>
                </Grid>
                <StackPanel x:Name="StationarySpringSliders">
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Spring strength:" Style="{StaticResource LabelText}"
                               ToolTip="How much centering weight to add when fully parked, as a fraction of full FFB. Start low; a strong spring snaps a direct-drive rim to center hard."/>
                    <Slider     Grid.Column="1" x:Name="StationarySpringStrengthSlider"
                                Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.25"
                                TickFrequency="0.25" ValueChanged="StationarySpringStrengthSlider_ValueChanged" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" x:Name="StationarySpringStrengthText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Fade-out (km/h):" Style="{StaticResource LabelText}"
                               ToolTip="The spring is at full strength when stopped and fades to nothing by this speed. Keep it low so it's gone before real cornering forces build."/>
                    <Slider     Grid.Column="1" x:Name="StationarySpringCutoffSlider"
                                Minimum="2" Maximum="30" SmallChange="1" LargeChange="5"
                                TickFrequency="2" ValueChanged="StationarySpringCutoffSlider_ValueChanged" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" x:Name="StationarySpringCutoffText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="12"/>
                </Grid>
                </StackPanel>

            </StackPanel>

            <!-- Experimental FFB detection. Surfaced on the main page so a user
                 with no force feedback can find it, but kept at the bottom of
                 the Master section so it isn't crammed between the primary
                 tuning controls. Synced with the copy in Advanced > FFB
                 pass-through and the FFBX access code. Outside
                 FfbPassthroughControls so it stays enabled regardless of the
                 skip-pass-through state. -->
            <CheckBox x:Name="ExperimentalFfbMainCheck" Content="Enable experimental FFB detection"
                      Margin="0,8,0,2" Checked="ExperimentalFfbDetectionMain_Changed" Unchecked="ExperimentalFfbDetectionMain_Changed"
                      ToolTip="Off by default. Turn this on if a game that should have force feedback is giving you none. It widens how the plugin finds your wheel's force feedback on the USB bus (helps some wheels, such as the RS50 in Forza). After enabling, load the game and drive for a few seconds. Turn it back off if it causes any trouble."/>
            <TextBlock Style="{StaticResource HelpText}" Margin="22,0,0,12"
                       Text="Try this if you are not getting force feedback in a game that should have it."/>

            <!-- (The old "Active car" Save/Delete box was removed: per-car
                 tuning now saves via each effect's ★/Save popover ("For this
                 car"), and deleting a car preset lives in Manage Presets. The
                 header car-preset picker still switches the active car preset.) -->

            <!-- FFB spike taming: comfort filter for over-the-top curb /
                 collision FFB. Pulled out into its own top-level section
                 (was nested inside Master's FFB controls) since it's a
                 distinct safety / comfort feature, not just FFB tuning.
                 Extra top margin so the header isn't crammed against the
                 stationary-spring controls in the Master section above. -->
            <Border Style="{StaticResource SectionHeaderBorder}" Margin="0,16,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FFB spike reduction" Style="{StaticResource SectionHeaderText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="SpikeReductionRevertBtn" Content="↶" Tag="SpikeReduction" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                    <Button Grid.Column="2" x:Name="SpikeReductionSaveBtn"   Content="Save…" Tag="SpikeReduction" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                </Grid>
            </Border>
            <CheckBox x:Name="SpikeTamingEnabledCheck" Content="FFB spike reduction (recommended for Assetto Corsa)"
                      FontWeight="SemiBold" Margin="0,0,0,4"
                      Checked="SpikeTamingEnabled_Changed" Unchecked="SpikeTamingEnabled_Changed"/>
            <!-- Spike reduction has two mutually exclusive methods: exactly
                 one runs when the box above is on, neither when it's off.
                 The selector and tuning stay readable even when it's off so
                 the method can be set any time. The active method's controls
                 show; the other method's are hidden (no graying). The label,
                 help text and description swap by method in code
                 (UpdateSpikeModeUi). The shared limit slider is one setting
                 (FfbSpikeMaxLsbPerMs) read as LSB/ms in slew or an LSB
                 threshold in transient. "Cap softness" is transient-only so
                 it only appears under Transient. -->
            <StackPanel x:Name="SpikeTamingBody" Margin="0,4,0,16">
                <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8"
                           Text="Some games deliver curb and collision FFB spikes well beyond what's safe or comfortable on stronger wheelbases (Assetto Corsa is the worst offender we've seen). Hits can be sharp enough to wrench the wheel against your grip, ruin a racing line, or strain your wrists on a long session. Pick one of the two methods below; it only applies while the box above is checked."/>
                <TextBlock Text="Method:" Style="{StaticResource LabelText}" Margin="0,2,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <RadioButton x:Name="SpikeModeTransientRadio" GroupName="SpikeMode"
                                 Content="Transient detector" VerticalAlignment="Center"
                                 Checked="SpikeMode_Changed"/>
                    <RadioButton x:Name="SpikeModeSlewRadio" GroupName="SpikeMode"
                                 Content="Slew-rate limiter (iRacing-style)" VerticalAlignment="Center"
                                 Margin="18,0,0,0" Checked="SpikeMode_Changed"/>
                </StackPanel>
                <TextBlock x:Name="SpikeModeDescription" Style="{StaticResource HelpText}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="FfbSpikeLimitLabel" Text="Slew rate (LSB/ms):" Style="{StaticResource LabelText}"/>
                    <Slider     Grid.Column="1" x:Name="FfbSpikeLimitSlider"
                                Minimum="0" Maximum="30000" SmallChange="500" LargeChange="2000"
                                TickFrequency="2500" ValueChanged="FfbSpikeLimitSlider_ValueChanged" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" x:Name="FfbSpikeLimitText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="2061"/>
                </Grid>
                <TextBlock Style="{StaticResource HelpText}" Margin="140,4,0,8" x:Name="FfbSpikeLimitHelp"/>
                <StackPanel x:Name="SpikeCapSoftnessRow">
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Cap softness (LSB):" Style="{StaticResource LabelText}"/>
                        <Slider     Grid.Column="1" x:Name="FfbPeakLimitSlider"
                                    Minimum="0" Maximum="20000" SmallChange="500" LargeChange="2000"
                                    TickFrequency="2000" ValueChanged="FfbPeakLimitSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="FfbPeakLimitText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1562"/>
                    </Grid>
                    <TextBlock Style="{StaticResource HelpText}" Margin="140,4,0,0"
                               Text="How hard spikes above the threshold get compressed. Peak force during a big hit asymptotes toward threshold plus this value. Transient method only."/>
                </StackPanel>
            </StackPanel>

            <!-- Effects -->
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="Effects" Style="{StaticResource SectionHeaderText}"/></Border>

            <!-- Audio capture (game audio → wheel). Lives outside the
                 telemetry-greyed panel because it works even when the game
                 emits no useful telemetry (custom SimHub games etc). -->
            <Expander x:Name="AudioExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="AudioEnabledCheck" Content="Audio capture (game audio → wheel)"
                                  FontWeight="SemiBold" VerticalAlignment="Center"
                                  Checked="AudioEnabled_Changed" Unchecked="AudioEnabled_Changed"/>
                        <Border x:Name="AudioNewBadge" Style="{StaticResource NewEffectBadge}">
                            <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                        <TextBlock x:Name="AudioOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                        <Button    x:Name="AudioRevertBtn"  Content="↶" Tag="Audio" Margin="14,0,0,0"
                                   Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                        <Button    x:Name="AudioSaveBtn"    Content="Save…" Tag="Audio"
                                   Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                        <Slider     Grid.Column="1" x:Name="AudioGainSlider"
                                    Minimum="0" Maximum="3.0" SmallChange="0.05" LargeChange="0.25"
                                    TickFrequency="0.5" ValueChanged="AudioGainSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="AudioGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Highpass (Hz):" Style="{StaticResource LabelText}"/>
                        <Slider     Grid.Column="1" x:Name="AudioHighpassSlider"
                                    Minimum="0" Maximum="200" SmallChange="5" LargeChange="20"
                                    TickFrequency="20" ValueChanged="AudioHighpassSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="AudioHighpassText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="30"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Lowpass (Hz):" Style="{StaticResource LabelText}"/>
                        <Slider     Grid.Column="1" x:Name="AudioFilterSlider"
                                    Minimum="100" Maximum="1500" SmallChange="10" LargeChange="50"
                                    TickFrequency="100" ValueChanged="AudioFilterSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="AudioFilterText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="350"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Level:" Style="{StaticResource LabelText}"/>
                        <ProgressBar Grid.Column="1" x:Name="AudioLevelMeter" Minimum="0" Maximum="1" Height="14" Foreground="#4CAF50"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Status:" Style="{StaticResource LabelText}"/>
                        <TextBlock Grid.Column="1" x:Name="CaptureStatusText" Text="Idle" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </Grid>

                    <!-- Power-user: per-game capture exe override. Hidden by
                         default; surfaces when auto-detect misses a game. -->
                    <Expander x:Name="CaptureNotWorkingExpander" IsExpanded="False" Margin="0,8,0,0">
                        <Expander.Header>
                            <TextBlock Text="Audio capture not picking up your game?" FontSize="12"/>
                        </Expander.Header>
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,4"
                                       Text="Type the game's exe name here (with or without &quot;.exe&quot;). Saved per-game and applied within 1 second."/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Capture exe:" Style="{StaticResource LabelText}"/>
                                <TextBox   Grid.Column="1" x:Name="CaptureExeOverrideBox"
                                           VerticalAlignment="Center" LostFocus="CaptureExeOverride_LostFocus"
                                           KeyDown="CaptureExeOverride_KeyDown"/>
                            </Grid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Expander>

            <!-- Telemetry-driven effects: greyed when a game is running but
                 emits no useful telemetry (e.g. SimHub custom games where
                 only audio capture produces output). When no game is loaded,
                 the panel stays enabled so the user can still tune presets
                 for future sessions. -->
            <StackPanel x:Name="TelemetryEffectsPanel">

                <!-- Engine pulse -->
                <Expander x:Name="EngineExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="EngineEnabledCheck" Content="Engine pulse (RPM-driven)"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="EngineEnabled_Changed" Unchecked="EngineEnabled_Changed"/>
                            <Border x:Name="EngineNewBadge" Style="{StaticResource NewEffectBadge}">
                                <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="EngineOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="EngineTest_Click"/>
                            <Button x:Name="EngineRevertBtn" Content="↶" Tag="Engine" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="EngineSaveBtn"   Content="Save…" Tag="Engine" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="EngineGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="EngineGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="EngineGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pitch:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="EnginePitchSlider" Minimum="0.25" Maximum="4.0" SmallChange="0.05" LargeChange="0.25"
                                        TickFrequency="0.25" ValueChanged="EnginePitchSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="EnginePitchText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="EngineWaveformCombo" SelectionChanged="EngineWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Lowpass (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="0 = disabled. Lowers buzzy harmonics on Square/Saw without changing pitch."/>
                            <Slider     Grid.Column="1" x:Name="EngineLowpassSlider" Minimum="0" Maximum="2000" SmallChange="10" LargeChange="50"
                                        TickFrequency="200" ValueChanged="EngineLowpassSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="EngineLowpassText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0"/>
                        </Grid>
                        <!-- Electric car behavior: applies only when the resolver
                             flags the active car as a pure EV. Combustion cars
                             ignore this. Per-car preset overrides the global. -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Electric cars:" Style="{StaticResource LabelText}"
                                       ToolTip="What EnginePulse does for cars detected as pure electric. Most users prefer the muted hum since real EVs aren't silent (many pump synthetic engine sound). Pick Silent if you want true silence on EVs."/>
                            <ComboBox  Grid.Column="1" x:Name="EngineElectricModeCombo" SelectionChanged="EngineElectricMode_Changed">
                                <ComboBoxItem Content="Muted hum (50%)"/>
                                <ComboBoxItem Content="Silent (off)"/>
                            </ComboBox>
                        </Grid>
                        <Separator Margin="0,4,0,8"/>
                        <!-- Engine type. Each entry implies its cylinder/rotor
                             count and firing pattern, so there's no separate
                             cylinder control. Auto defers to the car-resolver
                             (AC bake / Forza telemetry); Electric routes
                             through the EV behavior selector above; Custom
                             uses the firing-pattern textbox below. -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Engine type:" Style="{StaticResource LabelText}"
                                       ToolTip="Pick the engine that best matches the active car. Auto defers to detection; Electric uses the EV behavior above; Custom uses the firing pattern below."/>
                            <!-- Items are populated dynamically in SettingsControl.RebuildEngineLayoutDropdown
                                 so the user's saved customs can appear alongside built-ins, and
                                 "Custom..." / "Manage customs..." action entries reach their dialogs. -->
                            <ComboBox  Grid.Column="1" x:Name="EngineLayoutCombo" SelectionChanged="EngineLayout_Changed"/>
                        </Grid>
                        <!-- Auto-detect indicator: shows the layout the resolver
                             chose for the active car when the user has Auto
                             selected. Empty otherwise (explicit Layout in effect). -->
                        <TextBlock x:Name="EngineLayoutAutoText" Style="{StaticResource HelpText}" Margin="140,0,0,8" Text=""/>
                        <!-- Active pattern readout: shows what's being synthesized
                             for the currently selected engine type. Read-only.
                             Authoring custom engines happens in the Custom...
                             dialog, not inline. -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pattern:" Style="{StaticResource LabelText}"
                                       ToolTip="Diagnostic readout: comma-separated phase positions in [0, 1) where each pulse fires within one 720° engine cycle. Useful for submitting corrections if a built-in pattern sounds wrong."/>
                            <TextBox   Grid.Column="1" x:Name="EngineFiringPatternText"
                                       FontFamily="Consolas" IsReadOnly="True"/>
                        </Grid>
                        <!-- Submit/report engine-data button. Opens a Google
                             Form pre-filled with what the plugin auto-detected
                             and what the user has selected. Code sets label
                             and visibility per the EngineSubmitState classifier:
                               * no detection, user has tuned: "Submit engine
                                 data for this car..." (CONTRIB).
                               * detection present, user's committed values
                                 disagree: "Report wrong engine data for this
                                 car..." (CORRECTION).
                               * detection agrees / nothing tuned / engine
                                 section dirty: hidden.
                             Hiding while the engine section is dirty means
                             submissions reflect committed values, not
                             mid-tweak slider positions. -->
                        <Grid Margin="140,4,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Button x:Name="ReportEngineDataButton"
                                    HorizontalAlignment="Left" Padding="8,3"
                                    Click="ReportEngineDataButton_Click"
                                    Content="Submit engine data for this car..."
                                    ToolTip="Opens a Google Form pre-filled with what's auto-detected and what you've selected in the dropdowns / slider. Just hit Submit on the form, no typing needed and no account required."/>
                        </Grid>

                        <!-- High-RPM perceptibility helpers. On by default;
                             keep the engine feel present where the wheel
                             motor naturally rolls off the firing pulse. -->
                        <Separator Margin="0,8,0,8"/>
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,6"
                                   Text="Helps the engine still feel present at high RPM, where the wheel's motor can't keep up with the firing rate."/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="EngineLoadLayerCheck"
                                      Content="Load layer" VerticalAlignment="Center"
                                      Checked="EngineLoadLayer_Changed" Unchecked="EngineLoadLayer_Changed"
                                      ToolTip="Adds a low-frequency oscillation at the engine's cycle rate (RPM/120 Hz) alongside the firing pulse. Sits in the band the wheel actually moves at, so the engine keeps feeling present as the firing pulse rolls off at high RPM."/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="  Strength:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="EngineLoadLayerGainSlider" Minimum="0" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.1" ValueChanged="EngineLoadLayerGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="EngineLoadLayerGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.80"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="EngineHighRpmBoostCheck"
                                      Content="High-RPM boost" VerticalAlignment="Center"
                                      Checked="EngineHighRpmBoost_Changed" Unchecked="EngineHighRpmBoost_Changed"
                                      ToolTip="Pre-emphasis: extra firing-pulse gain ramping in above 50% RPM. Partially compensates for the wheel's natural high-frequency rolloff."/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="  Amount:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="EngineHighRpmBoostSlider" Minimum="0" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.1" ValueChanged="EngineHighRpmBoostSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="EngineHighRpmBoostText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.70"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Road bumps -->
                <Expander x:Name="BumpsExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="SlipEnabledCheck" Content="Road bumps / curbs (vertical jolts)"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="SlipEnabled_Changed" Unchecked="SlipEnabled_Changed"/>
                            <Border x:Name="BumpsNewBadge" Style="{StaticResource NewEffectBadge}">
                                <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="BumpsOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="BumpsTest_Click"/>
                            <Button x:Name="BumpsRevertBtn" Content="↶" Tag="Bumps" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="BumpsSaveBtn"   Content="Save…" Tag="Bumps" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="SlipGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="SlipGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="SlipGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="BumpsWaveformCombo" SelectionChanged="BumpsWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid x:Name="BumpsFreqRow" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Frequency (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="BumpsFreqSlider" Minimum="20" Maximum="300" SmallChange="1" LargeChange="10"
                                        TickFrequency="20" ValueChanged="BumpsFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="BumpsFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="60"/>
                        </Grid>

                        <!-- Surface texture (Forza-supplied SurfaceRumble + WheelOnRumbleStrip).
                             Has its own oscillator so the user can pick a higher freq /
                             brighter waveform than the heave path. Knobs stay visible
                             on non-Forza games but won't produce sound (source supplies
                             no SurfaceRumble). Clearly labeled (Forza) so users don't
                             waste time tuning controls that won't fire on AC etc. -->
                        <Border BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF" Margin="0,4,0,8" Padding="0,8,0,0">
                            <StackPanel>
                                <CheckBox x:Name="BumpsSurfaceEnabledCheck" Content="Surface texture (Forza)" FontWeight="SemiBold" Margin="0,0,0,4"
                                          Checked="BumpsSurfaceEnabled_Changed" Unchecked="BumpsSurfaceEnabled_Changed"
                                          ToolTip="Forza-only: drives a second oscillator from the per-tire SurfaceRumble channel. Continuous road feel that's stronger on dirt/grass and lighter on asphalt. Adds a leading-edge pulse on rumble-strip contact."/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface gain:" Style="{StaticResource LabelText}"/>
                                    <Slider     Grid.Column="1" x:Name="BumpsSurfaceGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                                TickFrequency="0.25" ValueChanged="BumpsSurfaceGainSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="BumpsSurfaceGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface freq (Hz):" Style="{StaticResource LabelText}"/>
                                    <Slider     Grid.Column="1" x:Name="BumpsSurfaceFreqSlider" Minimum="20" Maximum="600" SmallChange="5" LargeChange="25"
                                                TickFrequency="50" ValueChanged="BumpsSurfaceFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="BumpsSurfaceFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="120"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface waveform:" Style="{StaticResource LabelText}"/>
                                    <ComboBox  Grid.Column="1" x:Name="BumpsSurfaceWaveformCombo" SelectionChanged="BumpsSurfaceWaveform_Changed">
                                        <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Rumble scale:" Style="{StaticResource LabelText}"
                                               ToolTip="Multiplier on Forza's SurfaceRumble before driving the oscillator. 1.0 = use as-is. Bump up for more aggressive surface feel."/>
                                    <Slider     Grid.Column="1" x:Name="BumpsSurfaceRumbleScaleSlider" Minimum="0.1" Maximum="3.0" SmallChange="0.1" LargeChange="0.25"
                                                TickFrequency="0.25" ValueChanged="BumpsSurfaceRumbleScaleSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="BumpsSurfaceRumbleScaleText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                                </Grid>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Kerb pulse:" Style="{StaticResource LabelText}"
                                               ToolTip="Extra amplitude added on the rising edge of any wheel touching a rumble strip. 0 = disabled."/>
                                    <Slider     Grid.Column="1" x:Name="BumpsRumbleStripPulseSlider" Minimum="0" Maximum="1.5" SmallChange="0.05" LargeChange="0.1"
                                                TickFrequency="0.25" ValueChanged="BumpsRumbleStripPulseSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="BumpsRumbleStripPulseText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.50"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Expander>

                <!-- Traction loss -->
                <Expander x:Name="TractionExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="TractionEnabledCheck" Content="Traction loss (rear breaking loose / wheelspin)"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="TractionEnabled_Changed" Unchecked="TractionEnabled_Changed"/>
                            <Border x:Name="TractionNewBadge" Style="{StaticResource NewEffectBadge}">
                                <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="TractionOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="TractionTest_Click"/>
                            <Button x:Name="TractionRevertBtn" Content="↶" Tag="Traction" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="TractionSaveBtn"   Content="Save…" Tag="Traction" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="TractionGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="TractionGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TractionGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sensitivity:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="TractionSensitivitySlider" Minimum="0.1" Maximum="3.0" SmallChange="0.1" LargeChange="0.25"
                                        TickFrequency="0.25" ValueChanged="TractionSensitivitySlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TractionSensitivityText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="TractionWaveformCombo" SelectionChanged="TractionWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid x:Name="TractionFreqRow" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Frequency (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="TractionFreqSlider" Minimum="20" Maximum="300" SmallChange="1" LargeChange="10"
                                        TickFrequency="20" ValueChanged="TractionFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TractionFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="100"/>
                        </Grid>
                        <!-- Noise filter rows: only relevant for Noise waveform.
                             Collapsed otherwise so the panel doesn't show
                             controls that have no audible effect. -->
                        <Grid x:Name="TractionNoiseLpRow" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Noise lowpass (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="Cut high frequencies from noise. Lower = smoother rumble, higher = grittier."/>
                            <Slider     Grid.Column="1" x:Name="TractionNoiseLpSlider" Minimum="50" Maximum="1000" SmallChange="10" LargeChange="50"
                                        TickFrequency="100" ValueChanged="TractionNoiseLpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TractionNoiseLpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="250"/>
                        </Grid>
                        <Grid x:Name="TractionNoiseHpRow" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Noise highpass (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="Cut sub-audible drift / DC thump from noise. 0 disables."/>
                            <Slider     Grid.Column="1" x:Name="TractionNoiseHpSlider" Minimum="0" Maximum="200" SmallChange="5" LargeChange="20"
                                        TickFrequency="20" ValueChanged="TractionNoiseHpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="TractionNoiseHpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="30"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Gear shift -->
                <Expander x:Name="ShiftExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="ShiftEnabledCheck" Content="Gear shift thud"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="ShiftEnabled_Changed" Unchecked="ShiftEnabled_Changed"/>
                            <Border x:Name="ShiftNewBadge" Style="{StaticResource NewEffectBadge}">
                                <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="ShiftOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="ShiftTest_Click"/>
                            <Button x:Name="ShiftRevertBtn" Content="↶" Tag="Shift" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="ShiftSaveBtn"   Content="Save…" Tag="Shift" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="ShiftGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="ShiftGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="ShiftGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="ShiftWaveformCombo" SelectionChanged="ShiftWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Frequency (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="ShiftFreqSlider" Minimum="20" Maximum="100" SmallChange="1" LargeChange="5"
                                        TickFrequency="10" ValueChanged="ShiftFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="ShiftFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="40"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- ABS -->
                <Expander x:Name="AbsExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="AbsEnabledCheck" Content="ABS pulse"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="AbsEnabled_Changed" Unchecked="AbsEnabled_Changed"/>
                            <Border x:Name="AbsNewBadge" Style="{StaticResource NewEffectBadge}">
                                <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="AbsOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <TextBlock x:Name="AbsUnsupportedBadge" Style="{StaticResource UnsupportedBadge}"
                                       Text="not exposed by Forza UDP"
                                       ToolTip="Forza Horizon's Data Out telemetry doesn't include ABS pump activity, so this effect will stay silent in FH4/FH5/FH6 regardless of the values you set here."/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="AbsTest_Click"/>
                            <Button x:Name="AbsRevertBtn" Content="↶" Tag="Abs" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="AbsSaveBtn"   Content="Save…" Tag="Abs" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="AbsGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="AbsGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="AbsGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="AbsWaveformCombo" SelectionChanged="AbsWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mode:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="AbsModeCombo" SelectionChanged="AbsMode_Changed">
                                <ComboBoxItem Content="Pulse (rhythmic)"/>
                                <ComboBoxItem Content="PerTick (one click per ABS pump)"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Carrier (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="AbsFreqSlider" Minimum="30" Maximum="150" SmallChange="1" LargeChange="5"
                                        TickFrequency="10" ValueChanged="AbsFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="AbsFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="80"/>
                        </Grid>
                        <!-- Pulse rate / duty are only meaningful in Pulse mode.
                             Greyed when AbsMode = PerTick. -->
                        <StackPanel x:Name="AbsPulseControls">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pulse rate (Hz):" Style="{StaticResource LabelText}"/>
                                <Slider     Grid.Column="1" x:Name="AbsPulseFreqSlider" Minimum="3" Maximum="30" SmallChange="0.5" LargeChange="2"
                                            TickFrequency="2" ValueChanged="AbsPulseFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="AbsPulseFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pulse duty:" Style="{StaticResource LabelText}"/>
                                <Slider     Grid.Column="1" x:Name="AbsDutyCycleSlider" Minimum="0.1" Maximum="0.9" SmallChange="0.05" LargeChange="0.1"
                                            TickFrequency="0.1" ValueChanged="AbsDutyCycleSlider_ValueChanged" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="AbsDutyCycleText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.40"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <!-- Pit limiter (modal flag effect). Pulse train while the
                     pit limiter is engaged. Most modern racing sims surface
                     PitLimiterOn directly via SimHub. -->
                <Expander x:Name="PitLimiterExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="PitLimiterEnabledCheck" Content="Pit limiter"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="PitLimiterEnabled_Changed" Unchecked="PitLimiterEnabled_Changed"/>
                            <Border x:Name="PitLimiterNewBadge" Style="{StaticResource NewEffectBadge}">
                                <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="PitLimiterOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="PitLimiterTest_Click"/>
                            <Button x:Name="PitLimiterRevertBtn" Content="↶" Tag="PitLimiter" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="PitLimiterSaveBtn"   Content="Save…" Tag="PitLimiter" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="Continuous pulse train while the pit limiter is engaged. Feels like the engine being cut at low RPM. Source: SimHub StatusDataBase.PitLimiterOn (works for most racing sims that have a pit lane)."/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="PitLimiterGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="PitLimiterGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PitLimiterGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="PitLimiterWaveformCombo" SelectionChanged="PitLimiterWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Carrier (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="Tone within each pulse. Lower = deeper thud; higher = brighter."/>
                            <Slider     Grid.Column="1" x:Name="PitLimiterFreqSlider" Minimum="20" Maximum="150" SmallChange="1" LargeChange="5"
                                        TickFrequency="10" ValueChanged="PitLimiterFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PitLimiterFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="50"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pulse rate (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="How fast the pulse opens / closes. 5–10 Hz feels like a real pit limiter cadence."/>
                            <Slider     Grid.Column="1" x:Name="PitLimiterPulseFreqSlider" Minimum="3" Maximum="15" SmallChange="0.5" LargeChange="2"
                                        TickFrequency="1" ValueChanged="PitLimiterPulseFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PitLimiterPulseFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="6.0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pulse duty:" Style="{StaticResource LabelText}"
                                       ToolTip="Fraction of each pulse during which the carrier is audible. Higher = more sustained; lower = more punctuated."/>
                            <Slider     Grid.Column="1" x:Name="PitLimiterDutyCycleSlider" Minimum="0.1" Maximum="0.9" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.1" ValueChanged="PitLimiterDutyCycleSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PitLimiterDutyCycleText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.60"/>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Active amp:" Style="{StaticResource LabelText}"
                                       ToolTip="Peak amplitude while the limiter is engaged."/>
                            <Slider     Grid.Column="1" x:Name="PitLimiterActiveAmpSlider" Minimum="0" Maximum="0.6" SmallChange="0.02" LargeChange="0.05"
                                        TickFrequency="0.1" ValueChanged="PitLimiterActiveAmpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PitLimiterActiveAmpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.30"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- DRS (F1-style flag effect). Activation chirp on rising edge
                     plus low-amp sustained tone while wing is open. Source:
                     SimHub StatusDataBase.DRSEnabled (F1 / F1-like sims). -->
                <Expander x:Name="DrsExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="DrsEnabledCheck" Content="DRS"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="DrsEnabled_Changed" Unchecked="DrsEnabled_Changed"/>
                            <Border x:Name="DrsNewBadge" Style="{StaticResource NewEffectBadge}">
                                <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="DrsOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="DrsTest_Click"/>
                            <Button x:Name="DrsRevertBtn" Content="↶" Tag="Drs" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="DrsSaveBtn"   Content="Save…" Tag="Drs" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="Brief activation chirp on the rising edge of DRS, plus a low-amplitude sustained tone while the wing stays open. Silent on games that don't expose DRS. Source: SimHub StatusDataBase.DRSEnabled."/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="DrsGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,4,0,4" Text="Activation chirp (rising edge of DRS)" FontWeight="SemiBold"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"
                                       ToolTip="Shape of the brief blip on the rising edge."/>
                            <ComboBox  Grid.Column="1" x:Name="DrsWaveformCombo" SelectionChanged="DrsWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Carrier (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsActivationFreqSlider" Minimum="40" Maximum="200" SmallChange="1" LargeChange="5"
                                        TickFrequency="20" ValueChanged="DrsActivationFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsActivationFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="120"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Duration (ms):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsActivationMsSlider" Minimum="20" Maximum="200" SmallChange="5" LargeChange="20"
                                        TickFrequency="20" ValueChanged="DrsActivationMsSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsActivationMsText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="60"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Amp:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsActivationAmpSlider" Minimum="0" Maximum="0.6" SmallChange="0.02" LargeChange="0.05"
                                        TickFrequency="0.1" ValueChanged="DrsActivationAmpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsActivationAmpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.30"/>
                        </Grid>
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,4,0,4" Text="Sustained tone (while DRS held open). Set amp to 0 for chirp-only mode." FontWeight="SemiBold"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"
                                       ToolTip="Shape of the held trail. Independent from the activation chirp so a sharp Square blip can have a softer Sine trail."/>
                            <ComboBox  Grid.Column="1" x:Name="DrsSustainedWaveformCombo" SelectionChanged="DrsSustainedWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Carrier (Hz):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsSustainedFreqSlider" Minimum="20" Maximum="150" SmallChange="1" LargeChange="5"
                                        TickFrequency="10" ValueChanged="DrsSustainedFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsSustainedFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="70"/>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Amp:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DrsSustainedAmpSlider" Minimum="0" Maximum="0.4" SmallChange="0.02" LargeChange="0.05"
                                        TickFrequency="0.05" ValueChanged="DrsSustainedAmpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DrsSustainedAmpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.12"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Collision (variable-amplitude thud on impact). Magnitude
                     comes from PC2's mLastOpponentCollisionMagnitude
                     directly, or is derived from a sudden lateral/vertical
                     accel spike (>5g) for any other source. Global-only
                     for v1 (no per-car override slot yet). -->
                <Expander x:Name="CollisionExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="CollisionEnabledCheck" Content="Collision"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="CollisionEnabled_Changed" Unchecked="CollisionEnabled_Changed"/>
                            <Border x:Name="CollisionNewBadge" Style="{StaticResource NewEffectBadge}">
                                <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="CollisionOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="CollisionTest_Click"/>
                            <Button x:Name="CollisionRevertBtn" Content="↶" Tag="Collision" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="CollisionSaveBtn"   Content="Save…" Tag="Collision" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="Single thud on impact, amplitude scales with collision force. Sources: PC2 reads its native impact magnitude directly; other sources derive from sudden lateral/vertical accel spikes above ~5g (well above hard cornering or curbs)."/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="CollisionGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="CollisionGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="CollisionGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="1.00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Min threshold:" Style="{StaticResource LabelText}"
                                       ToolTip="Lower = lighter contacts trigger. Raise if light scrapes are too noisy."/>
                            <Slider     Grid.Column="1" x:Name="CollisionMinThresholdSlider" Minimum="0.05" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.1" ValueChanged="CollisionMinThresholdSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="CollisionMinThresholdText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.20"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Max amplitude:" Style="{StaticResource LabelText}"
                                       ToolTip="Cap on the loudest hit. Safety knob for wrists / wheelbase."/>
                            <Slider     Grid.Column="1" x:Name="CollisionMaxAmpSlider" Minimum="0.2" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.1" ValueChanged="CollisionMaxAmpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="CollisionMaxAmpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.85"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Carrier (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="Lower = deeper thud. 50 Hz default."/>
                            <Slider     Grid.Column="1" x:Name="CollisionFreqSlider" Minimum="20" Maximum="120" SmallChange="1" LargeChange="5"
                                        TickFrequency="10" ValueChanged="CollisionFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="CollisionFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="50"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Duration (ms):" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="CollisionEnvelopeMsSlider" Minimum="40" Maximum="300" SmallChange="5" LargeChange="20"
                                        TickFrequency="20" ValueChanged="CollisionEnvelopeMsSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="CollisionEnvelopeMsText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="120"/>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"
                                       ToolTip="Shape of the impact thud. Square is the punchiest; Sine is softer."/>
                            <ComboBox  Grid.Column="1" x:Name="CollisionWaveformCombo" SelectionChanged="CollisionWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Rev limiter (modal RPM-threshold effect). Hard buzz when
                     RPM reaches the shift point / limiter, held while bouncing
                     off it. Independent of engine pulse; an unmistakable
                     "shift now / on the limiter" cue. Works wherever RPM is
                     reported (the universal SimHub fallback included). -->
                <Expander x:Name="RevLimiterExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="RevLimiterEnabledCheck" Content="Rev limiter"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="RevLimiterEnabled_Changed" Unchecked="RevLimiterEnabled_Changed"/>
                            <Border x:Name="RevLimiterNewBadge" Style="{StaticResource NewEffectBadge}">
                                <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="RevLimiterOverrideBadge" Style="{StaticResource OverrideBadge}"/>
                            <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="RevLimiterTest_Click"/>
                            <Button x:Name="RevLimiterRevertBtn" Content="↶" Tag="RevLimiter" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="RevLimiterSaveBtn"   Content="Save…" Tag="RevLimiter" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="A hard buzz that engages when RPM reaches the shift point and holds while you sit on (or bounce off) the limiter. A clearer shift cue than the engine-pulse change near redline, for when you run engine pulse low or just want an unmistakable signal. Triggers off RPM, so it works in any game that reports it."/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gain:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="RevLimiterGainSlider" Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.25" ValueChanged="RevLimiterGainSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="RevLimiterGainText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.10"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Engage mode:" Style="{StaticResource LabelText}"
                                       ToolTip="Auto trusts the game: it fires at the redline when the game reports a real one, otherwise at a percentage of the rev limit. If you get no rev-limiter buzz (some games report a wrong redline), switch to 'Percentage of rev limit' and set the engage % below."/>
                            <ComboBox  Grid.Column="1" x:Name="RevLimiterEngageModeCombo" SelectionChanged="RevLimiterEngageMode_Changed">
                                <ComboBoxItem Content="Auto (trust the game)"/><ComboBoxItem Content="Percentage of rev limit"/><ComboBoxItem Content="At reported redline"/>
                            </ComboBox>
                        </Grid>
                        <Grid x:Name="RevLimiterThresholdRow" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Engage at (% rev limit):" Style="{StaticResource LabelText}"
                                       ToolTip="Fraction of the car's hard rev limit at which the buzz starts. Used for games without a separate redline (e.g. Forza). Games that report a real redline (Assetto Corsa, iRacing) fire right at the redline instead, so this is hidden for them."/>
                            <Slider     Grid.Column="1" x:Name="RevLimiterThresholdSlider" Minimum="0.50" Maximum="1.00" SmallChange="0.01" LargeChange="0.05"
                                        TickFrequency="0.05" ValueChanged="RevLimiterThresholdSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="RevLimiterThresholdText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="85%"/>
                        </Grid>
                        <TextBlock x:Name="RevLimiterRedlineNote" Style="{StaticResource HelpText}" Visibility="Collapsed" Margin="0,0,0,8"
                                   Text="This game reports the car's redline, so the buzz fires at the redline. Use the offset below to fire a little before it (early shift cue) or after. (The engage % only applies to games without a redline, like Forza.)"/>
                        <Grid x:Name="RevLimiterOffsetRow" Margin="0,0,0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Redline offset:" Style="{StaticResource LabelText}"
                                       ToolTip="Shift the engage point relative to the car's redline. Negative fires the buzz before the redline (an early shift cue); positive fires it after. 0 = right at the redline. Only used when firing at a real redline; the percentage path ignores it."/>
                            <Slider     Grid.Column="1" x:Name="RevLimiterOffsetSlider" Minimum="-3000" Maximum="1000" SmallChange="50" LargeChange="250"
                                        TickFrequency="250" ValueChanged="RevLimiterOffsetSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="RevLimiterOffsetText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Waveform:" Style="{StaticResource LabelText}"/>
                            <ComboBox  Grid.Column="1" x:Name="RevLimiterWaveformCombo" SelectionChanged="RevLimiterWaveform_Changed">
                                <ComboBoxItem Content="Sine"/><ComboBoxItem Content="Square"/><ComboBoxItem Content="Saw"/><ComboBoxItem Content="Triangle"/><ComboBoxItem Content="Noise"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Carrier (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="Tone within each pulse. Higher reads as a more urgent buzz."/>
                            <Slider     Grid.Column="1" x:Name="RevLimiterFreqSlider" Minimum="30" Maximum="200" SmallChange="1" LargeChange="5"
                                        TickFrequency="10" ValueChanged="RevLimiterFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="RevLimiterFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="90"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pulse rate (Hz):" Style="{StaticResource LabelText}"
                                       ToolTip="How fast the buzz stutters. Faster feels like an aggressive soft-cut limiter."/>
                            <Slider     Grid.Column="1" x:Name="RevLimiterPulseFreqSlider" Minimum="5" Maximum="40" SmallChange="0.5" LargeChange="2"
                                        TickFrequency="5" ValueChanged="RevLimiterPulseFreqSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="RevLimiterPulseFreqText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="20.0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pulse duty:" Style="{StaticResource LabelText}"
                                       ToolTip="Fraction of each pulse during which the carrier is audible. Higher = more sustained; lower = more punctuated."/>
                            <Slider     Grid.Column="1" x:Name="RevLimiterDutyCycleSlider" Minimum="0.1" Maximum="0.9" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.1" ValueChanged="RevLimiterDutyCycleSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="RevLimiterDutyCycleText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.50"/>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Active amp:" Style="{StaticResource LabelText}"
                                       ToolTip="Peak amplitude while engaged."/>
                            <Slider     Grid.Column="1" x:Name="RevLimiterActiveAmpSlider" Minimum="0" Maximum="0.6" SmallChange="0.02" LargeChange="0.05"
                                        TickFrequency="0.1" ValueChanged="RevLimiterActiveAmpSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="RevLimiterActiveAmpText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.35"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Airborne ducking. A coordinator, not a voice: it produces
                     no haptic of its own, it pulls down the OTHER effects while
                     the car is off the ground so jumps / crest pops don't fire
                     phantom slide, engine, or road feedback. Detection comes
                     from the enhanced sources (AC wheel load, Forza suspension
                     droop); the universal SimHub path can't tell, so it's a
                     no-op there. Global (no per-car override / Save button):
                     edits persist immediately. -->
                <Expander x:Name="AirborneExpander" IsExpanded="False" Margin="0,0,0,4" Expanded="EffectExpander_Expanded">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="AirborneEnabledCheck" Content="Airborne ducking"
                                      FontWeight="SemiBold" VerticalAlignment="Center"
                                      Checked="AirborneEnabled_Changed" Unchecked="AirborneEnabled_Changed"/>
                            <Border x:Name="AirborneNewBadge" Style="{StaticResource NewEffectBadge}">
                                <TextBlock Text="NEW" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <Button x:Name="AirborneRevertBtn" Content="↶" Tag="Airborne" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="AirborneSaveBtn"   Content="Save…" Tag="Airborne" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="Cuts vibrations while the car is in the air, so a jump feels weightless instead of buzzing as if the tyres were still on the track. Everything comes back the moment you land. Choose how far to turn things down and which effects to cut below (the engine keeps pulsing by default, since it's still revving). Works in Assetto Corsa and Forza, the games that report enough to know the car has left the ground; it does nothing elsewhere."/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Reduction:" Style="{StaticResource LabelText}"
                                       ToolTip="How far to turn the chosen effects down while airborne. 100% = fully silent; lower values just dial them back."/>
                            <Slider     Grid.Column="1" x:Name="AirborneReductionSlider" Minimum="0" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.1" ValueChanged="AirborneReductionSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="AirborneReductionText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="100%"/>
                        </Grid>
                        <TextBlock Text="Duck these while airborne:" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox x:Name="AirborneDuckEngineCheck"      Content="Engine pulse"   Width="150" Margin="0,0,0,6" Checked="AirborneToggle_Changed" Unchecked="AirborneToggle_Changed"/>
                            <CheckBox x:Name="AirborneDuckAudioCheck"       Content="Captured audio" Width="150" Margin="0,0,0,6" Checked="AirborneToggle_Changed" Unchecked="AirborneToggle_Changed"/>
                            <CheckBox x:Name="AirborneDuckRoadBumpsCheck"   Content="Road bumps"     Width="150" Margin="0,0,0,6" Checked="AirborneToggle_Changed" Unchecked="AirborneToggle_Changed"/>
                            <CheckBox x:Name="AirborneDuckTractionCheck"    Content="Traction loss"  Width="150" Margin="0,0,0,6" Checked="AirborneToggle_Changed" Unchecked="AirborneToggle_Changed"/>
                            <CheckBox x:Name="AirborneDuckRevLimiterCheck"  Content="Rev limiter"    Width="150" Margin="0,0,0,6" Checked="AirborneToggle_Changed" Unchecked="AirborneToggle_Changed"/>
                            <CheckBox x:Name="AirborneDuckGearShiftCheck"   Content="Gear shift"     Width="150" Margin="0,0,0,6" Checked="AirborneToggle_Changed" Unchecked="AirborneToggle_Changed"/>
                            <CheckBox x:Name="AirborneDuckAbsCheck"         Content="ABS"            Width="150" Margin="0,0,0,6" Checked="AirborneToggle_Changed" Unchecked="AirborneToggle_Changed"/>
                            <CheckBox x:Name="AirborneDuckPitLimiterCheck"  Content="Pit limiter"    Width="150" Margin="0,0,0,6" Checked="AirborneToggle_Changed" Unchecked="AirborneToggle_Changed"/>
                            <CheckBox x:Name="AirborneDuckDrsCheck"         Content="DRS"            Width="150" Margin="0,0,0,6" Checked="AirborneToggle_Changed" Unchecked="AirborneToggle_Changed"/>
                            <CheckBox x:Name="AirborneDuckCollisionCheck"   Content="Collision"      Width="150" Margin="0,0,0,6" Checked="AirborneToggle_Changed" Unchecked="AirborneToggle_Changed"/>
                        </WrapPanel>
                    </StackPanel>
                </Expander>

            </StackPanel> <!-- /TelemetryEffectsPanel -->

            <!-- Rev/shift LEDs (iRacing + MAIRA). MAIRA users lose the wheel's
                 LEDs (iRacing's Trueforce being off takes them with it); these
                 toggles plus MAIRA's matching toggle bring them back. Drives
                 rim or base LEDs depending on the wheel. -->
            <StackPanel x:Name="RpmLedSection" Visibility="Collapsed" Margin="0,20,0,0">
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="Rev/shift LEDs (iRacing)" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                Text="Running MAIRA turns iRacing's Trueforce off, which also turns your wheel's LEDs off. With these toggles on (and MAIRA's matching toggle), TF4ALL drives the LEDs again from your RPM. Click Test to check they light up. If they do not work, use Feedback then Report an issue and attach your logs so I can take a look."/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <CheckBox x:Name="RpmLedEnabledCheck" Content="Drive the wheel's LEDs in iRacing"
                          VerticalAlignment="Center"
                          Checked="RpmLedEnabled_Changed" Unchecked="RpmLedEnabled_Changed"
                          ToolTip="Only active in iRacing with MAIRA. No effect in other games."/>
                <Button Content="Test" Style="{StaticResource EffectTestButton}" Click="RpmLedTest_Click"/>
            </StackPanel>
            <CheckBox x:Name="MairaPassthroughCheck" Content="Auto-link with MAIRA (recommended)"
                      VerticalAlignment="Center" Margin="0,0,0,6"
                      Checked="MairaPassthrough_Changed" Unchecked="MairaPassthrough_Changed"
                      ToolTip="Leave on. When you turn on MAIRA's matching 'Pass FFB through TF4ALL' toggle, the two link up automatically and your LEDs come back. With MAIRA's toggle off, TF4ALL works exactly as before."/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="LED status:" Style="{StaticResource LabelText}"/>
                <TextBlock Grid.Column="1" x:Name="RpmLedStatusText" Text="(idle)" FontSize="11" Opacity="0.85"/>
            </Grid>
            <TextBlock Style="{StaticResource HelpText}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"
                Text="Your LEDs and Trueforce haptics work together once MAIRA's 'Pass FFB through TF4ALL' toggle is on. Get MAIRA below."/>
            <TextBlock Margin="0,0,0,8" FontSize="12">
                <Hyperlink Foreground="#FF4DA3FF" Click="GetMaira_Click">
                    <Run Text="Get MAIRA Refactored (recommended for iRacing)"/>
                </Hyperlink>
            </TextBlock>
            </StackPanel> <!-- /RpmLedSection -->

            <!-- Sidechain ducking + Performance moved into the Advanced
                 Settings modal. See AdvancedSettingsHost near the bottom. -->

            <!-- Forza Data Out (UDP). Forza titles emit telemetry over UDP
                 instead of shared memory; the user enables UDP RACE TELEMETRY
                 in the in-game Settings → HUD and Gameplay menu and points it
                 at the IP/port set here. Two real-world gotchas:
                  - MS Store / UWP build: Windows network isolation blocks
                    UDP loopback. User has to run CheckNetIsolation.exe to
                    add a loopback exemption (or send to a LAN IP).
                  - Steam build: FH5 sends to the gateway IP (a long-known
                    bug Playground hasn't fixed). User has to send to their
                    LAN IP, not 127.0.0.1.
                 This whole section is collapsed unless a Forza title is the
                 active game (ShouldShowForzaSection), so non-Forza users
                 never see it. -->
            <StackPanel x:Name="ForzaSection" Visibility="Collapsed" Margin="0,20,0,0">
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="Forza telemetry (UDP)" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                Text="In Forza Horizon 4/5/6, open Settings → HUD and Gameplay → UDP RACE TELEMETRY. Turn DATA OUT ON, set DATA OUT IP ADDRESS to 127.0.0.1, and set DATA OUT IP PORT to the Port shown below. That is the whole setup. The listener is always on for Forza; per-tire surface rumble, kerbs, and cylinder count flow through automatically."/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Port:" Style="{StaticResource LabelText}"/>
                <TextBox   Grid.Column="1" x:Name="ForzaPortBox" LostFocus="ForzaPort_LostFocus" KeyDown="ForzaPort_KeyDown" VerticalAlignment="Center"
                           ToolTip="Match this in Forza's DATA OUT IP PORT. Default 5300; pick anything if it collides with another listener (SimHub's typical 4123, Sim Racing Studio's 4123, etc.)."/>
                <TextBlock Grid.Column="2" Style="{StaticResource HelpText}" Margin="8,0,0,0" VerticalAlignment="Center"
                           Text="Takes effect immediately."/>
            </Grid>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Bind address:" Style="{StaticResource LabelText}"/>
                <TextBox   Grid.Column="1" x:Name="ForzaBindBox" LostFocus="ForzaBind_LostFocus" KeyDown="ForzaBind_KeyDown" VerticalAlignment="Center"
                           ToolTip="Local IP to listen on. 0.0.0.0 = all interfaces (recommended). Use a specific LAN IP only if you want to filter."/>
                <TextBlock Grid.Column="2" Style="{StaticResource HelpText}" Margin="8,0,0,0" VerticalAlignment="Center"
                           Text="0.0.0.0 = listen on every network adapter."/>
            </Grid>
            <Grid Margin="0,4,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Status:" Style="{StaticResource LabelText}"/>
                <TextBlock Grid.Column="1" x:Name="ForzaStatusText" Text="(idle)" FontSize="11" Opacity="0.85"/>
            </Grid>
            <!-- Auto-discovered alternate port banner. Shown when the
                 plugin scanned candidate ports and found Forza packets on
                 one we're not bound to. One-click switch + dismiss. -->
            <Border x:Name="ForzaDiscoveryBanner" Background="#3300A8FF" BorderBrush="#00A8FF" BorderThickness="1"
                    CornerRadius="3" Padding="8" Margin="0,4,0,8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ForzaDiscoveryText" FontSize="11" TextWrapping="Wrap"
                               VerticalAlignment="Center" MaxWidth="380"
                               Text="Forza packets detected on a different port."/>
                    <Button x:Name="ForzaDiscoveryAdoptButton" Content="Switch" Width="80" Height="22" FontSize="11"
                            Margin="10,0,4,0" Click="ForzaDiscoveryAdopt_Click"/>
                    <Button x:Name="ForzaDiscoveryDismissButton" Content="Dismiss" Width="80" Height="22" FontSize="11"
                            Click="ForzaDiscoveryDismiss_Click"/>
                </StackPanel>
            </Border>

            <!-- Coexistence forwarder. Forza only sends to one destination, so
                 if the user wants both Trueforce haptics AND SimHub dashboards,
                 they point Forza at us and we relay raw packet bytes verbatim
                 to SimHub. Default off. Explicit opt-in keeps un-forwarded
                 packets out of the network when the user doesn't run SimHub. -->
            <Border BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF" Margin="0,4,0,8" Padding="0,8,0,0">
                <StackPanel>
                    <CheckBox x:Name="ForzaForwardEnabledCheck" Content="Also forward to SimHub (dashboards, ShakeIt / Buttkicker, etc.)" Click="ForzaForwardEnabled_Changed" Margin="0,0,0,4"
                              FontWeight="SemiBold"
                              ToolTip="Enable when you also use SimHub for Forza (dashboards, ShakeIt bass shakers / Buttkicker, anything SimHub drives). Forza can only send telemetry to one place, so this plugin receives it and re-broadcasts every packet verbatim to SimHub."/>
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,6" FontSize="11"
                               Text="This plugin sits between Forza and SimHub: Forza sends telemetry to the plugin, and the plugin passes a copy to SimHub, so both work. Forza only sends to one place, which is why it must point at this plugin, not at SimHub.&#10;1. In SimHub, open Games then Forza Horizon 5/6 and note the UDP port it uses. If SimHub has an &quot;automatically configure&quot; option for Forza's data output, turn it OFF, or it will keep overwriting the setting you make in step 2.&#10;2. In Forza's telemetry settings: Data Out IP = 127.0.0.1, Data Out Port = this plugin's listen port (the Port field above, default 5300). This must be a different number than SimHub's port from step 1.&#10;3. Enable this box. Set the forward host to 127.0.0.1 and the forward port to SimHub's port from step 1.&#10;4. Drive for a moment and check the &quot;Forwarded:&quot; line below. Once it shows packets, SimHub's dashboards and bass shakers are back."/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Forward to host:" Style="{StaticResource LabelText}"/>
                        <TextBox   Grid.Column="1" x:Name="ForzaForwardHostBox" LostFocus="ForzaForwardHost_LostFocus" KeyDown="ForzaForwardHost_KeyDown" VerticalAlignment="Center"
                                   ToolTip="127.0.0.1 if SimHub runs on the same PC. A LAN IP (or hostname) for a separate SimHub host."/>
                        <TextBlock Grid.Column="2" Text="port:" Style="{StaticResource LabelText}" Margin="8,0,0,0"/>
                        <TextBox   Grid.Column="3" x:Name="ForzaForwardPortBox" LostFocus="ForzaForwardPort_LostFocus" KeyDown="ForzaForwardPort_KeyDown" VerticalAlignment="Center" Width="120" HorizontalAlignment="Left"
                                   ToolTip="The port SimHub is listening on for Forza Data Out. Match this to the value in SimHub's Forza game settings."/>
                    </Grid>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Forwarded:" Style="{StaticResource LabelText}"/>
                        <TextBlock Grid.Column="1" x:Name="ForzaForwardStatusText" Text="(disabled)" FontSize="11" Opacity="0.85"/>
                    </Grid>
                </StackPanel>
            </Border>
            <Expander x:Name="ForzaTroubleshootExpander" IsExpanded="False" Margin="0,8,0,16">
                <Expander.Header>
                    <TextBlock Text="Not receiving packets?" FontSize="12"/>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,4" FontSize="11"
                               Text="Most setups receive fine on 127.0.0.1. If you're getting zero packets, work through these:"/>
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,4" FontSize="11"
                               Text="• Confirm Forza's DATA OUT is ON, and its IP and PORT match this plugin (IP 127.0.0.1, PORT = the Port field above)."/>
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,4" FontSize="11"
                               Text="• Port collision with SimHub or another tool? Pick a different port here, then update Forza's DATA OUT IP PORT to match."/>
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,4" FontSize="11"
                               Text="• Still nothing on 127.0.0.1: set Forza's DATA OUT IP ADDRESS to your PC's LAN IP (e.g. 192.168.x.x) instead, and leave the bind address here at 0.0.0.0. This gets around localhost quirks on some installs."/>
                    <TextBlock Style="{StaticResource HelpText}" FontSize="11"
                               Text="• Firewall: Windows Defender may prompt the first time the listener opens. Allow it on private/domain networks."/>
                </StackPanel>
            </Expander>
            </StackPanel> <!-- /ForzaSection -->

            <!-- F1 Telemetry (UDP). EA / Codemasters F1 series emits a rich
                 UDP telemetry stream the user enables in Settings → Telemetry
                 Settings. We target F1 25's wire format (PacketFormat=2025);
                 older years receive packets but skip parsing with a clear log
                 line. Recommend 60 Hz Send Rate; warn if the observed rate
                 drops well below that. -->
            <StackPanel x:Name="F1Section" Visibility="Collapsed">
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="F1 telemetry (UDP)" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                Text="In F1 25, open Settings → Telemetry Settings. Set UDP Telemetry to On, UDP IP Address to 127.0.0.1, UDP Port to the port below, UDP Send Rate to 60Hz, and UDP Format to 2025. Enables direct per-wheel slip, KERS deployment, pit limiter, DRS, and surface type."/>
            <CheckBox x:Name="F1EnabledCheck" Content="Enable F1 UDP listener" Click="F1Enabled_Changed" Margin="0,0,0,8"
                      ToolTip="When off, F1 titles fall back to SimHub's universal telemetry (60 Hz, no direct slip, no KERS)."/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Port:" Style="{StaticResource LabelText}"/>
                <TextBox   Grid.Column="1" x:Name="F1PortBox" LostFocus="F1Port_LostFocus" KeyDown="F1Port_KeyDown" VerticalAlignment="Center"
                           ToolTip="Match this in F1's UDP Port. Default 20777."/>
                <TextBlock Grid.Column="2" Style="{StaticResource HelpText}" Margin="8,0,0,0" VerticalAlignment="Center"
                           Text="Takes effect immediately."/>
            </Grid>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Bind address:" Style="{StaticResource LabelText}"/>
                <TextBox   Grid.Column="1" x:Name="F1BindBox" LostFocus="F1Bind_LostFocus" KeyDown="F1Bind_KeyDown" VerticalAlignment="Center"
                           ToolTip="0.0.0.0 listens on every interface (recommended)."/>
                <TextBlock Grid.Column="2" Style="{StaticResource HelpText}" Margin="8,0,0,0" VerticalAlignment="Center"
                           Text="0.0.0.0 = listen on every network adapter."/>
            </Grid>
            <CheckBox x:Name="F1AlwaysListenCheck" Content="Always listen (use for unrecognized F1 titles)" Click="F1AlwaysListen_Changed" Margin="0,4,0,4"
                      ToolTip="Keep the F1 source open even when SimHub doesn't recognize the running game."/>
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Status:" Style="{StaticResource LabelText}"/>
                <TextBlock Grid.Column="1" x:Name="F1StatusText" Text="(idle)" FontSize="11" Opacity="0.85"/>
            </Grid>
            <!-- Auto-discovered alternate port banner (F1). Same flow as Forza. -->
            <Border x:Name="F1DiscoveryBanner" Background="#3300A8FF" BorderBrush="#00A8FF" BorderThickness="1"
                    CornerRadius="3" Padding="8" Margin="0,4,0,4" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="F1DiscoveryText" FontSize="11" TextWrapping="Wrap"
                               VerticalAlignment="Center" MaxWidth="380"
                               Text="F1 packets detected on a different port."/>
                    <Button x:Name="F1DiscoveryAdoptButton" Content="Switch" Width="80" Height="22" FontSize="11"
                            Margin="10,0,4,0" Click="F1DiscoveryAdopt_Click"/>
                    <Button x:Name="F1DiscoveryDismissButton" Content="Dismiss" Width="80" Height="22" FontSize="11"
                            Click="F1DiscoveryDismiss_Click"/>
                </StackPanel>
            </Border>
            <!-- Send-rate warning. Shown only when packets are arriving but
                 the observed rate is well below 60 Hz; we recommend the user
                 bump UDP Send Rate in F1's Telemetry Settings. -->
            <Border x:Name="F1RateWarning" Background="#33FFC107" BorderBrush="#FFC107" BorderThickness="1"
                    CornerRadius="3" Padding="8" Margin="0,4,0,8" Visibility="Collapsed">
                <TextBlock x:Name="F1RateWarningText" FontSize="11" TextWrapping="Wrap"
                           Text="UDP Send Rate looks low. Set it to 60Hz in F1 25's Telemetry Settings for the most responsive haptics."/>
            </Border>

            <!-- Coexistence forwarder. F1 only sends to one destination, so
                 if the user wants both Trueforce haptics AND SimHub
                 dashboards, they point F1 at us and we relay raw packet
                 bytes verbatim to SimHub. Default off. -->
            <Border BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF" Margin="0,4,0,8" Padding="0,8,0,0">
                <StackPanel>
                    <CheckBox x:Name="F1ForwardEnabledCheck" Content="Also forward to SimHub (dashboards, ShakeIt / Buttkicker, etc.)" Click="F1ForwardEnabled_Changed" Margin="0,0,0,4"
                              FontWeight="SemiBold"
                              ToolTip="Enable when you also use SimHub for F1 (dashboards, ShakeIt bass shakers / Buttkicker, anything SimHub drives). F1 can only send telemetry to one place, so this plugin receives it and re-broadcasts every packet verbatim to SimHub."/>
                    <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,6" FontSize="11"
                               Text="This plugin sits between F1 and SimHub: F1 sends telemetry to the plugin, and the plugin passes a copy to SimHub, so both work. F1 only sends to one place, which is why it must point at this plugin, not at SimHub.&#10;1. In SimHub, open Games then F1 25 and note the UDP port it uses. If SimHub has an &quot;automatically configure&quot; option for F1's telemetry, turn it OFF, or it will keep overwriting the setting you make in step 2.&#10;2. In F1's telemetry settings: UDP IP = 127.0.0.1, UDP port = this plugin's listen port (the Port field above, default 5300). This must be a different number than SimHub's port from step 1.&#10;3. Enable this box. Set the forward host to 127.0.0.1 and the forward port to SimHub's port from step 1.&#10;4. Drive for a moment and check the &quot;Forwarded:&quot; line below. Once it shows packets, SimHub's dashboards and bass shakers are back."/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Forward to host:" Style="{StaticResource LabelText}"/>
                        <TextBox   Grid.Column="1" x:Name="F1ForwardHostBox" LostFocus="F1ForwardHost_LostFocus" KeyDown="F1ForwardHost_KeyDown" VerticalAlignment="Center"
                                   ToolTip="127.0.0.1 if SimHub runs on the same PC. A LAN IP (or hostname) for a separate SimHub host."/>
                        <TextBlock Grid.Column="2" Text="port:" Style="{StaticResource LabelText}" Margin="8,0,0,0"/>
                        <TextBox   Grid.Column="3" x:Name="F1ForwardPortBox" LostFocus="F1ForwardPort_LostFocus" KeyDown="F1ForwardPort_KeyDown" VerticalAlignment="Center" Width="120" HorizontalAlignment="Left"
                                   ToolTip="The port SimHub is listening on for F1 UDP telemetry. Match this to the value in SimHub's F1 25 game settings."/>
                    </Grid>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Forwarded:" Style="{StaticResource LabelText}"/>
                        <TextBlock Grid.Column="1" x:Name="F1ForwardStatusText" Text="(disabled)" FontSize="11" Opacity="0.85"/>
                    </Grid>
                </StackPanel>
            </Border>
            </StackPanel> <!-- /F1Section -->

            <!-- Diagnostics moved into the Advanced Settings modal. See
                 AdvancedSettingsHost near the bottom. -->

            <!-- The standalone "Presets" section was removed: preset handling is
                 now unified in the context card up top (pick + ★ Save all +
                 conditional Set-as-default + Save as new inline with the game
                 preset dropdown; Manage presets… at the bottom of that card). -->

            <!-- Backup & sync. Two smart buttons: Export opens the pack
                 picker (preselects the current car, hides built-ins);
                 Import auto-detects the file kind (preset, car preset,
                 pack, or full settings backup). -->
            <!-- Top margin: when the Forza/F1 sections above are hidden (most
                 users), this is the first section after the effects list and
                 would otherwise sit flush against the last effect's 4px margin
                 (this margin formerly lived on the removed Presets header). -->
            <Border Style="{StaticResource SectionHeaderBorder}" Margin="0,28,0,12"><TextBlock Text="Backup &amp; sync" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8"
                       Text="Share presets and car tunings with other users. Export bundles your picks into a single file; Import auto-detects whatever file you point it at."/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button x:Name="ExportButton" Content="Export…" Width="140" Height="28" Margin="0,0,8,0" Click="Export_Click"
                        ToolTip="Pick which presets and car tunings to bundle into a shareable file."/>
                <Button x:Name="ImportButton" Content="Import…" Width="140" Height="28" Click="Import_Click"
                        ToolTip="Import a preset, car preset, pack, or full settings backup. The file kind is auto-detected."/>
            </StackPanel>

            <!-- Support development -->
            <Border Style="{StaticResource SectionHeaderBorder}"><TextBlock Text="Support development" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,10" FontSize="12"
                Text="If this plugin made your wheel feel better, a tip is appreciated but never expected. Cheers."/>
            <!-- Custom-templated button: SimHub's theme overrides Button.Background
                 on stock buttons. A full ControlTemplate replaces the visual tree
                 so the Ko-fi brand red survives intact. -->
            <Button x:Name="DonateButton" Click="Donate_Click" Cursor="Hand"
                    HorizontalAlignment="Left" Width="200" Height="44" Margin="0,0,0,8">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DonateBd" Background="#FF5E5B" CornerRadius="8" BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.35"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Canvas Grid.Column="0" Width="22" Height="22" Margin="14,0,8,0" VerticalAlignment="Center">
                                    <Path Stroke="White" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M 7,2 C 9,4 5,6 7,8"/>
                                    <Path Stroke="White" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M 12,2 C 14,4 10,6 12,8"/>
                                    <Path Fill="White" Data="M 3,10 L 14,10 L 13,18 C 13,19.5 12,20 10.5,20 L 6.5,20 C 5,20 4,19.5 4,18 Z"/>
                                    <Path Stroke="White" StrokeThickness="1.6" Fill="Transparent"
                                          Data="M 14,12 C 18,12 18,17 14,17"/>
                                </Canvas>
                                <TextBlock Grid.Column="1" Text="Support on Ko-fi"
                                           Foreground="White" FontWeight="Bold" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DonateBd" Property="Background" Value="#E54E4B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DonateBd" Property="Background" Value="#CC3F3D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock Text="ko-fi.com/mhytee" FontSize="11" Opacity="0.5" Margin="0,0,0,8"/>

            <!-- Spread the word. Always available (unlike the one-and-done
                 banner up top). Word of mouth is the only thing that gets
                 this in front of people, so it's a first-class action here,
                 not buried. Same dialog the banner opens. -->
            <Border Style="{StaticResource SectionHeaderBorder}" Margin="0,16,0,0"><TextBlock Text="Spread the word" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                Text="Almost nobody knows this plugin exists; sharing is the best way to help get the word out."/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button x:Name="SharePanelButton" Content="Share TF4ALL…" Width="160" Height="28" Margin="0,0,8,0"
                        Click="SharePanelButton_Click"
                        ToolTip="Post on X, Reddit, or Facebook, or open the Nexus Mods / GitHub page."/>
            </StackPanel>

            <!-- Report-issue + repo link: separate from cylinder reporting; this
                 is for everything else (bugs, feature requests, weird behavior). -->
            <Border Style="{StaticResource SectionHeaderBorder}" Margin="0,16,0,0"><TextBlock Text="Feedback" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                Text="Found a bug, weird behavior, or have a feature request? Open an issue on GitHub."/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="ReportIssueButton" Content="Report an issue…" Width="160" Height="26"
                        Click="ReportIssue_Click" Margin="0,0,8,0"
                        ToolTip="Opens a new GitHub issue. Pre-fills plugin version and active game so you don't have to type it."/>
                <Button x:Name="ExportLogsButton" Content="Export logs…" Width="120" Height="26"
                        Click="ExportLogs_Click" Margin="0,0,8,0"
                        ToolTip="Zips your SimHub logs + Trueforce settings to your Desktop. Attach the zip to your GitHub issue so I can debug what's happening on your machine."/>
                <Button x:Name="OpenRepoButton" Content="Open project on GitHub" Width="180" Height="26"
                        Click="OpenRepo_Click"
                        ToolTip="github.com/Mhytee/Trueforce-For-All"/>
            </StackPanel>

            <!-- Advanced settings entrypoint. Opens a modal hosting the three
                 Expanders parked invisibly in AdvancedSettingsHost below
                 (Performance, Sidechain ducking, Diagnostics). The Click
                 handler re-parents the host into a Window and restores it
                 on close, which keeps every existing per-control event
                 handler reachable without changes. -->
            <Border Style="{StaticResource SectionHeaderBorder}" Margin="0,16,0,0"><TextBlock Text="Advanced" Style="{StaticResource SectionHeaderText}"/></Border>
            <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                Text="Performance / latency tuning, sidechain ducking, and diagnostics. Rarely needed for day-to-day tuning."/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button x:Name="OpenAdvancedSettingsButton" Content="Advanced settings…"
                        Width="180" Height="28"
                        Click="OpenAdvancedSettings_Click"
                        ToolTip="Open the advanced settings dialog."/>
            </StackPanel>

            <!-- Hidden host for the Advanced Settings modal contents. Lives
                 invisibly at the tail of the main panel so InitializeComponent
                 still wires up every named field below; OpenAdvancedSettings_Click
                 re-parents this StackPanel into a Window for display and
                 restores it here when the user closes the dialog. -->
            <StackPanel x:Name="AdvancedSettingsHost" Visibility="Collapsed">

                <!-- FFB pass-through. Only relevant for games that ship native
                     Trueforce (AC Rally, iRacing, etc). For those games the
                     same toggle is also promoted to the main panel so users
                     don't have to dig for it. -->
                <Expander x:Name="FfbPassthroughExpander" IsExpanded="False" Margin="0,0,0,8">
                    <Expander.Header>
                        <TextBlock Text="FFB pass-through" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <CheckBox x:Name="FfbSkipPassthroughCheck" Content="Skip FFB pass-through (native Trueforce games)"
                                  Margin="0,0,0,2" Checked="FfbSkipPassthrough_Changed" Unchecked="FfbSkipPassthrough_Changed"/>
                        <TextBlock Style="{StaticResource HelpText}" Margin="22,0,0,12"
                                   Text="Enable for games with native Trueforce support (e.g. AC Rally, iRacing). Plugin effects still play, but the wheel's force comes from the game's own FFB path instead of being mirrored from our capture. Avoids fighting with the game's own writes to the wheel."/>

                        <!-- Experimental FFB detection. Off by default so the
                             proven capture path is unchanged for everyone; opt
                             in if a game that should have force feedback gives
                             none. Widens how the tap recognizes the wheel's FFB
                             on the bus (HID++ report 0x12 + faster index
                             resolve; helps e.g. the RS50 in Forza, issue #8).
                             Synced with the copy on the main page and the FFBX
                             access code. -->
                        <CheckBox x:Name="ExperimentalFfbCheck" Content="Enable experimental FFB detection"
                                  Margin="0,4,0,2" Checked="ExperimentalFfbDetection_Changed" Unchecked="ExperimentalFfbDetection_Changed"
                                  ToolTip="Off by default. Turn this on if a game that should have force feedback is giving you none. It widens how the plugin finds your wheel's force feedback on the USB bus (helps some wheels, such as the RS50 in Forza). After enabling, load the game and drive for a few seconds. Turn it back off if it causes any trouble."/>
                        <TextBlock Style="{StaticResource HelpText}" Margin="22,0,0,12"
                                   Text="Try this if you are not getting force feedback in a game that should have it. Load the game and drive for a few seconds after turning it on. Leave it off if your force feedback already works."/>
                    </StackPanel>
                </Expander>

                <!-- Performance / latency tuning. Per-machine, NOT preset-saved
                     (a friend's CPU/scheduler is different from yours).
                     Collapsed Expander since most users never need to touch it. -->
                <Expander x:Name="PerformanceExpander" IsExpanded="False" Margin="0,0,0,8">
                    <Expander.Header>
                        <TextBlock Text="Performance" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                            Text="Smaller ring buffers = less latency between game and wheel, but require Windows to wake our threads on time. Auto starts at the smallest sizes and ratchets up if dropouts occur (one-way; survived size persists across sessions). Manual locks specific sizes (useful for streamers who want guaranteed-stable behavior, or to force-test the lowest values)."/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mode:" VerticalAlignment="Center" Opacity="0.7"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="PerfAutoRadio"   Content="Auto" GroupName="PerfMode"
                                             Margin="0,0,16,0" VerticalAlignment="Center"
                                             ToolTip="Start at smallest ring sizes; ratchet up on persistent dropouts. Survived size is remembered across sessions."
                                             Checked="PerfMode_Changed"/>
                                <RadioButton x:Name="PerfManualRadio" Content="Manual" GroupName="PerfMode"
                                             Margin="0,0,16,0" VerticalAlignment="Center"
                                             ToolTip="Lock the slider values. No automatic changes. Use for streaming or force-testing."
                                             Checked="PerfMode_Changed"/>
                                <Button x:Name="PerfResetButton" Content="Reset to lowest" Padding="10,2" VerticalAlignment="Center"
                                        ToolTip="Drop both rings back to the smallest configured value. In Auto mode the ratchet will re-discover whether your machine can hold them."
                                        Click="PerfReset_Click"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Trueforce ring:" VerticalAlignment="Center" Opacity="0.7"
                                       ToolTip="Sample buffer between the audio mixer and the USB stream. Smaller = lower wheel latency, but Windows must wake the stream thread on time."/>
                            <Slider     Grid.Column="1" x:Name="PerfTfRingSlider"
                                        Minimum="8" Maximum="64" SmallChange="8" LargeChange="8"
                                        TickFrequency="8" IsSnapToTickEnabled="True"
                                        ValueChanged="PerfTfRingSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PerfTfRingText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="8 (2ms)"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Audio ring:" VerticalAlignment="Center" Opacity="0.7"
                                       ToolTip="Sample buffer between WASAPI loopback and the audio mixer. WASAPI typically delivers ~12 decimated samples per ~3ms callback; 16 fits that with headroom. Setting 8 only works if your audio driver supports a ~2ms WASAPI period (uncommon). If you set 8 and hear continuous clicks, the auto-ratchet (Auto mode) will bump you back up."/>
                            <Slider     Grid.Column="1" x:Name="PerfAudioRingSlider"
                                        Minimum="8" Maximum="128" SmallChange="8" LargeChange="8"
                                        TickFrequency="8" IsSnapToTickEnabled="True"
                                        ValueChanged="PerfAudioRingSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="PerfAudioRingText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="16 (4ms)"/>
                        </Grid>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Live counters:" VerticalAlignment="Top" Opacity="0.7" Margin="0,2,0,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="PerfCountersText" FontSize="11" Opacity="0.8"
                                           Text="Trueforce ring: 0 underruns/min · Audio ring: 0 glitches/min"/>
                                <TextBlock Style="{StaticResource HelpText}" FontSize="11" Margin="0,2,0,0"
                                           Text="Counters tally events in a rolling 60-second window. If they're going up, your machine is glitching at the current ring size; Auto mode will bump it up."/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Sidechain ducking. When transient effects fire,
                     continuous effects duck to make room. -->
                <Expander x:Name="DuckingExpander" IsExpanded="False" Margin="0,0,0,8">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Sidechain ducking" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button x:Name="DuckingRevertBtn" Content="↶" Tag="Ducking" Style="{StaticResource EffectRevertButton}" Click="EffectRevert_Click"/>
                            <Button x:Name="DuckingSaveBtn"   Content="Save…" Tag="Ducking" Style="{StaticResource EffectSaveButton}" Click="EffectSave_Click"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource HelpText}" Margin="0,0,0,8" FontSize="12"
                            Text="When transient effects (gear shift, ABS, road bumps, traction loss) fire, continuous effects (engine pulse, audio capture) duck to make room."/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Depth:" Style="{StaticResource LabelText}"/>
                            <Slider     Grid.Column="1" x:Name="DuckDepthSlider"
                                        Minimum="0" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.1" ValueChanged="DuckDepthSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DuckDepthText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.50"/>
                        </Grid>
                        <Expander x:Name="AdvancedDuckingExpander" IsExpanded="False" Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock Text="Advanced (envelope)" FontSize="12"/>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Attack (ms):" Style="{StaticResource LabelText}"/>
                                    <Slider     Grid.Column="1" x:Name="DuckAttackSlider"
                                                Minimum="1" Maximum="100" SmallChange="1" LargeChange="5"
                                                TickFrequency="10" ValueChanged="DuckAttackSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="DuckAttackText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="5"/>
                                </Grid>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Release (ms):" Style="{StaticResource LabelText}"/>
                                    <Slider     Grid.Column="1" x:Name="DuckReleaseSlider"
                                                Minimum="10" Maximum="500" SmallChange="5" LargeChange="25"
                                                TickFrequency="50" ValueChanged="DuckReleaseSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="DuckReleaseText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="80"/>
                                </Grid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Expander>

                <!-- Diagnostics. Wheel / stream / FFB / telemetry status.
                     Useful for troubleshooting; rarely needed otherwise. -->
                <Expander x:Name="DiagnosticsExpander" IsExpanded="False" Margin="0,0,0,8">
                    <Expander.Header>
                        <TextBlock Text="Diagnostics" FontSize="13" FontWeight="SemiBold"/>
                    </Expander.Header>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Wheel:" Style="{StaticResource LabelText}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="WheelText" Text="(checking...)"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Stream:" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StreamText" Text="(checking...)" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="FFB pass-through:" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock x:Name="FfbTapText" Text="(checking...)" VerticalAlignment="Center"/>
                            <!-- Visible only when USBPcap can't be located. Lets users
                                 point at a non-standard install, or reinstall the
                                 driver from the bundled setup without re-running our
                                 installer. Toggled from code-behind on the tick. -->
                            <Button x:Name="UsbPcapBrowseButton" Content="Browse..."
                                    Style="{StaticResource LinkButton}" Margin="10,0,0,0"
                                    Visibility="Collapsed"
                                    Click="UsbPcapBrowse_Click"
                                    ToolTip="Point at USBPcapCMD.exe if USBPcap is installed somewhere off the default Program Files path."/>
                            <Button x:Name="UsbPcapReinstallButton" Content="Reinstall"
                                    Style="{StaticResource LinkButton}" Margin="10,0,0,0"
                                    Visibility="Collapsed"
                                    Click="UsbPcapReinstall_Click"
                                    ToolTip="Run the bundled USBPcap installer (requires admin). Use this if USBPcap was uninstalled or the install is broken."/>
                            <!-- Always visible escape hatch. Auto-discovery via
                                 USBPcap's descriptor cache can miss hot-plugged
                                 wheels; this lets users scan every USB device
                                 on every USBPcap interface and pick the wheel
                                 by hand. Selection persists across restarts. -->
                            <Button x:Name="UsbPcapPickDeviceButton" Content="Pick device manually..."
                                    Style="{StaticResource LinkButton}" Margin="10,0,0,0"
                                    Click="UsbPcapPickDevice_Click"
                                    ToolTip="Scan every USBPcap interface and pick your wheel manually. Use this if auto-discovery can't find your wheel even though it works in HID."/>
                        </StackPanel>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Telemetry:" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TelemetrySourceText" Text="(checking...)" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Active sources:" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="VoicesText" Text="0" Margin="0,4,0,0"/>
                        <!-- Raw USB packet logging. Off by default. When on,
                             every OUT transfer (host → wheel) on every
                             endpoint is captured to usb-trace.pcap alongside
                             SimHub's logs, in real pcap format so Wireshark
                             with USBPcap opens it directly. Export Logs
                             bundles the trace when present. Caps at 50 MB;
                             toggle off + on to reset. Wider than ep0 only so
                             FFB protocols on non-control endpoints are
                             visible too (some Logitech wheels use ep1 OUT). -->
                        <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                  x:Name="LogUsbBytesCheck"
                                  Margin="0,12,0,0"
                                  Content="Log raw USB FFB packets to usb-trace.pcap (for support)"
                                  Checked="LogUsbBytes_Changed" Unchecked="LogUsbBytes_Changed"
                                  ToolTip="Off by default. When on, captures every USB OUT transfer to your wheel (any endpoint, any transfer type) as a pcap file alongside SimHub's logs. Open in Wireshark with USBPcap. Use only when support asks for it: the file grows several KB/sec during active FFB. Capped at 50 MB; toggle off and on to reset."/>

                        <!-- Self-test: one click that aggregates every health
                             signal into a pass/fail checklist and fires a
                             short buzz so the user can confirm the wheel
                             physically responds. Non-destructive, reads live
                             state; doesn't reopen a healthy device. -->
                        <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                                x:Name="SelfTestButton"
                                Content="Run self-test"
                                HorizontalAlignment="Left" Margin="0,14,0,0"
                                Padding="10,3" Click="SelfTest_Click"
                                ToolTip="Checks USBPcap, G HUB, wheel, stream, FFB pass-through and telemetry, then sends a short test buzz so you can confirm the wheel responds."/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                   x:Name="SelfTestResultText"
                                   Visibility="Collapsed"
                                   Margin="0,8,0,0" TextWrapping="Wrap"
                                   FontFamily="Consolas" FontSize="12"/>
                    </Grid>
                </Expander>

                <!-- Tester access code. Unhides the rim-LED / MAIRA
                     passthrough section (MAIRA side still in PR, RS50/G923
                     unvalidated, so it stays out of the public UI). Type
                     MAIRA or TEST to unlock; persists for this install. -->
                <StackPanel Orientation="Horizontal" Margin="0,18,0,2">
                    <TextBlock Text="Access code:" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                    <TextBox x:Name="AccessCodeBox" Width="120" Height="24" Margin="8,0,0,0"
                             VerticalAlignment="Center" VerticalContentAlignment="Center" Padding="4,0"
                             Background="#FF2D2D30" Foreground="White" CaretBrush="White"
                             BorderBrush="#FF7A7A7A" BorderThickness="1"
                             LostFocus="AccessCode_Changed" KeyDown="AccessCode_KeyDown"/>
                    <TextBlock x:Name="AccessCodeStatus" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
