<Window x:Class="TrueforceForAll.Plugin.ManagePresetsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage presets"
        Width="860" Height="600"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="#FF2A2A2A"
        TextElement.Foreground="#FFEAEAEA">
    <Window.Resources>
        <Style x:Key="HelpText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <!-- Custom-templated row button. SimHub's stock theme greys every
             Button.Background regardless of IsEnabled, which made the dialog's
             action buttons look the same color whether they were usable or
             not. The template here uses explicit Background colors per state
             so disabled buttons are visibly dimmer than enabled ones. -->
        <Style x:Key="RowButton" TargetType="Button">
            <Setter Property="Width" Value="92"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#5A5A5A" CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6E6E6E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#454545"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#363636"/>
                                <Setter Property="Foreground" Value="#777"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" x:Name="Tabs">
            <!-- ===================== Game presets ===================== -->
            <TabItem Header="Game presets">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HelpText}" Margin="0,0,0,8"
                               Text="Every preset in your library. Rename, duplicate, or delete without needing the matching game loaded. The 'Default for' column shows which games auto-load this preset. Built-in presets shipped with the plugin can't be renamed or deleted; saving changes while on one forks a new user preset."/>
                    <ListView Grid.Row="1" x:Name="GameList" SelectionMode="Single"
                              SelectionChanged="GameList_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="34">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      Checked="RowCheckBox_Toggled" Unchecked="RowCheckBox_Toggled"
                                                      HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Preset name"  Width="240" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Built-in"     Width="80"  DisplayMemberBinding="{Binding BuiltinLabel}"/>
                                <GridViewColumn Header="Default for"  Width="320" DisplayMemberBinding="{Binding DefaultForLabel}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="True">
                        <TextBlock x:Name="GameCheckedLabel" DockPanel.Dock="Right" VerticalAlignment="Center"
                                   Foreground="#FFD54F" FontSize="11" Margin="8,0,0,0" Text=""/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="GameRenameBtn"     Content="Rename…"        Style="{StaticResource RowButton}" Click="GameRename_Click"     IsEnabled="False"/>
                            <Button x:Name="GameDuplicateBtn"  Content="Duplicate…"     Style="{StaticResource RowButton}" Click="GameDuplicate_Click"  IsEnabled="False"/>
                            <Button x:Name="GameDeleteBtn"     Content="Delete"         Style="{StaticResource RowButton}" Click="GameDelete_Click"     IsEnabled="False"/>
                            <Button x:Name="GameSetDefaultBtn" Content="Set default…"   Style="{StaticResource RowButton}" Width="120" Click="GameSetDefault_Click" IsEnabled="False"
                                    ToolTip="Bind this preset as the auto-load default for a game you've seen before."/>
                            <Button x:Name="GameClearDefaultBtn" Content="Clear default…" Style="{StaticResource RowButton}" Width="120" Click="GameClearDefault_Click" IsEnabled="False"
                                    ToolTip="Remove a game's auto-load binding to this preset."/>
                            <!-- Edit button hidden: the offline-edit flow exists but isn't
                                 stable enough to expose yet and adds confusion next to
                                 Rename/Duplicate. Code path (handler + RequestedEditPresetName)
                                 kept in place so it can be re-enabled without rebuilding. -->
                            <Button x:Name="GameEditBtn" Content="Edit" Style="{StaticResource RowButton}" Click="GameEdit_Click" IsEnabled="False"
                                    Visibility="Collapsed"
                                    ToolTip="Load this preset into the live settings panel for offline editing. The main UI gets a banner with Save / Save as new / Discard."/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ===================== Car presets ===================== -->
            <TabItem Header="Car presets">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HelpText}" Margin="0,0,0,8"
                               Text="Every car preset on disk across all cars. Stored as files under PluginsData/Common/TrueforceCars. Each car can have multiple presets, built-in factory defaults plus any user-saved or imported ones. Active = the preset that loads when this car shows up; switch the active one with 'Set as active'."/>
                    <ListView Grid.Row="1" x:Name="CarList" SelectionMode="Single"
                              SelectionChanged="CarList_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="34">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      Checked="RowCheckBox_Toggled" Unchecked="RowCheckBox_Toggled"
                                                      HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Car ID"      Width="210" DisplayMemberBinding="{Binding CarId}"/>
                                <GridViewColumn Header="Preset name" Width="190" DisplayMemberBinding="{Binding PresetName}"/>
                                <GridViewColumn Header="Game"        Width="130" DisplayMemberBinding="{Binding GameLabel}"/>
                                <GridViewColumn Header="Built-in"    Width="70"  DisplayMemberBinding="{Binding BuiltinLabel}"/>
                                <GridViewColumn Header="Active"      Width="60"  DisplayMemberBinding="{Binding ActiveLabel}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="True">
                        <TextBlock x:Name="CarCheckedLabel" DockPanel.Dock="Right" VerticalAlignment="Center"
                                   Foreground="#FFD54F" FontSize="11" Margin="8,0,0,0" Text=""/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="CarRenameBtn"    Content="Rename…"      Style="{StaticResource RowButton}" Click="CarRename_Click"    IsEnabled="False"/>
                            <Button x:Name="CarDuplicateBtn" Content="Duplicate…"   Style="{StaticResource RowButton}" Click="CarDuplicate_Click" IsEnabled="False"/>
                            <Button x:Name="CarDeleteBtn"    Content="Delete"       Style="{StaticResource RowButton}" Click="CarDelete_Click"    IsEnabled="False"/>
                            <Button x:Name="CarSetActiveBtn" Content="Set as active" Style="{StaticResource RowButton}" Width="120" Click="CarSetActive_Click" IsEnabled="False"
                                    ToolTip="Make this the preset that loads for this car. The matching CarDefaults entry is rewritten."/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ===================== Custom engines ===================== -->
            <TabItem Header="Custom engines">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HelpText}" Margin="0,0,0,8"
                               Text="Your saved custom engines. Delete removes them from the library, presets that referenced them fall back to silence until repicked from the engine dropdown. Built-in layouts (V8 cross-plane, Rotary, etc.) are shipped with the plugin and aren't shown here."/>
                    <ListView Grid.Row="1" x:Name="CustomList" SelectionMode="Single"
                              SelectionChanged="CustomList_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="34">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      Checked="RowCheckBox_Toggled" Unchecked="RowCheckBox_Toggled"
                                                      HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Name"   Width="270" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Type"   Width="130" DisplayMemberBinding="{Binding TypeLabel}"/>
                                <GridViewColumn Header="Detail" Width="220" DisplayMemberBinding="{Binding Detail}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="True">
                        <TextBlock x:Name="CustomCheckedLabel" DockPanel.Dock="Right" VerticalAlignment="Center"
                                   Foreground="#FFD54F" FontSize="11" Margin="8,0,0,0" Text=""/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="CustomEditBtn"   Content="Edit…"   Style="{StaticResource RowButton}" Click="CustomEdit_Click"   IsEnabled="False"/>
                            <Button x:Name="CustomDeleteBtn" Content="Delete"  Style="{StaticResource RowButton}" Click="CustomDelete_Click" IsEnabled="False"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Export…" Width="100" Height="28" Margin="0,0,8,0" Click="DialogExport_Click"
                        ToolTip="Pick which presets and car tunings to bundle into a shareable file. Same flow as the Export button on the main panel."/>
                <Button Content="Import…" Width="100" Height="28" Click="DialogImport_Click"
                        ToolTip="Import a preset, car preset, pack, or full settings backup. The file kind is auto-detected."/>
            </StackPanel>
            <Button Grid.Column="2" Content="Close" Width="84" Height="28" Click="Close_Click" IsCancel="True" IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
