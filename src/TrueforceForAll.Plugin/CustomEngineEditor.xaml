<Window x:Class="TrueforceForAll.Plugin.CustomEngineEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom engine"
        Width="540" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style x:Key="HelpText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Name:" Style="{StaticResource LabelText}"/>
            <TextBox Grid.Column="1" x:Name="NameTextBox" Padding="4,2"/>
        </Grid>

        <!-- Electric checkbox -->
        <CheckBox Grid.Row="1" x:Name="ElectricCheck"
                  Content="Electric engine (no firing pattern)"
                  Margin="140,0,0,8"
                  Checked="Electric_Changed" Unchecked="Electric_Changed"
                  ToolTip="When checked, this engine plays no firing pulses. Use for EVs or hybrids where you want the muted-hum or silent treatment."/>

        <!-- Combustion: Firing pattern shape -->
        <Grid Grid.Row="2" x:Name="ShapeRow" Margin="0,0,0,8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Firing pattern:" Style="{StaticResource LabelText}"
                       ToolTip="Picks how pulses distribute within one 720° engine cycle. Even-fire covers Inline / Boxer / V60° / V90° / V8 flat-plane / V10 / V12 / W12-16 / V4."/>
            <ComboBox Grid.Column="1" x:Name="ShapeCombo" SelectionChanged="Shape_Changed">
                <ComboBoxItem Content="Even-fire (cyl count picks Inline / Boxer / V / W)"/>
                <ComboBoxItem Content="V8 cross-plane (American muscle, locks at 8)"/>
                <ComboBoxItem Content="V6 odd-fire 90° (locks at 6)"/>
                <ComboBoxItem Content="V-twin 90° (Ducati, locks at 2)"/>
                <ComboBoxItem Content="V-twin 60° (Aprilia, KTM, locks at 2)"/>
                <ComboBoxItem Content="V-twin 45° (Harley, locks at 2)"/>
                <ComboBoxItem Content="Inline-4 crossplane (Yamaha R1, locks at 4)"/>
                <ComboBoxItem Content="Rotary (rotor count)"/>
                <ComboBoxItem Content="Parallel twin 180° (MT-07, RS660, locks at 2)"/>
                <ComboBoxItem Content="V4 Twin Pulse (Panigale, locks at 4)"/>
                <ComboBoxItem Content="Boxer-4 rumble (Subaru, locks at 4)"/>
            </ComboBox>
        </Grid>

        <!-- Combustion: Cylinder/rotor count -->
        <Grid Grid.Row="3" x:Name="CountRow" Margin="0,0,0,8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="CountLabel" Text="Cylinders:" Style="{StaticResource LabelText}"/>
            <Slider Grid.Column="1" x:Name="CountSlider" Minimum="1" Maximum="16" SmallChange="1" LargeChange="2"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    ValueChanged="Count_ValueChanged" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" x:Name="CountText" VerticalAlignment="Center" HorizontalAlignment="Right" Text="4"/>
        </Grid>

        <!-- Combustion: Pattern textbox -->
        <Grid Grid.Row="4" x:Name="PatternRow" Margin="0,0,0,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Pattern:" Style="{StaticResource LabelText}"
                       ToolTip="Comma-separated phase positions in [0, 1) representing where each pulse fires within one 720° cycle. Optional ':amplitude' suffix per pulse. Auto-fills when you pick a shape / count above; edit freely for expert tuning."/>
            <TextBox Grid.Column="1" x:Name="PatternTextBox" FontFamily="Consolas" Padding="4,2"/>
        </Grid>

        <TextBlock Grid.Row="5" x:Name="PatternHelp" Style="{StaticResource HelpText}" Margin="140,0,0,8"
                   Text="Format: 0, 0.125, 0.25, ...  Optional weights: 0:1.0, 0.125:0.85, ..."/>

        <!-- Electric: Behavior -->
        <Grid Grid.Row="6" x:Name="ElectricBehaviorRow" Margin="0,0,0,8" Visibility="Collapsed">
            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Behavior:" Style="{StaticResource LabelText}"
                       ToolTip="Muted hum keeps the firing-frequency tone at half amplitude (real EVs aren't silent — many pump synthetic sound). Silent fully mutes the engine effect for this car."/>
            <ComboBox Grid.Column="1" x:Name="ElectricBehaviorCombo">
                <ComboBoxItem Content="Muted hum (50%)"/>
                <ComboBoxItem Content="Silent (off)"/>
            </ComboBox>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="8" Margin="0,16,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel" Width="84" Height="28" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
            <Button Grid.Column="2" Content="Save" Width="84" Height="28" Click="Save_Click" IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
