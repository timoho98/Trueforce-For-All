# Working notes: USB captures, parser experiments, ad-hoc analysis scripts.
# Big binary pcaps (~120 MB) live here; never commit.
captures/

# Ad-hoc working artifacts. Convention: throwaway scratch files get a __
# prefix so they're easy to ignore in bulk. pcap/pcapng captures anywhere
# should never be committed even if they escape captures/.
__*
*.pcap
*.pcapng

# Local-only dev/test harnesses. Useful while developing on a real wheel,
# but not part of the user-facing product, so kept out of the public repo.
# Files stay on disk locally; just untracked.
/src/SineTest/
/src/DiscoveryTest/
/src/UsbPcapTest/
